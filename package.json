{
  "name": "techies-tools",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host=127.0.0.1",
    "check": "astro check",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1",
    "deploy:preview": "astro build --mode preview && wrangler deploy",
    "deploy:production": "astro build --mode production && wrangler deploy",
    "cf:types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@lucide/astro": "^1.24.0",
    "astro": "^7.0.9",
    "css-tree": "3.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/css-tree": "2.3.11",
    "typescript": "^5.8.3",
    "wrangler": "^4.110.0"
  }
}
