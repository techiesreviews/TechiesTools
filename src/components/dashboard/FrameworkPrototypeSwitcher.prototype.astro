---
// PROTOTYPE — remove after a preview direction is selected.
const variants = [
  ["A", "Design system"],
  ["B", "Curated homepage"],
];
---

<nav class="prototype-switcher" aria-label="Prototype variants" data-prototype-switcher>
  <button type="button" aria-label="Previous prototype" data-prototype-previous>←</button>
  <strong data-prototype-label>A — Design system</strong>
  <button type="button" aria-label="Next prototype" data-prototype-next>→</button>
  <div hidden>{variants.map(([key,label]) => <i data-prototype-option={key} data-prototype-name={label}></i>)}</div>
</nav>

<style>
  .prototype-switcher { position:fixed; z-index:1000; inset:auto 50% 1rem auto; display:grid; grid-template-columns:2rem minmax(10rem,auto) 2rem; align-items:center; overflow:hidden; border:1px solid rgb(255 255 255/.2); border-radius:999px; background:#111827; color:white; box-shadow:0 .8rem 2.5rem rgb(15 23 42/.3); transform:translateX(50%); }
  .prototype-switcher button { display:grid; place-items:center; width:2rem; height:2rem; border:0; background:transparent; color:inherit; cursor:pointer; }
  .prototype-switcher button:hover { background:rgb(255 255 255/.12); }
  .prototype-switcher strong { padding:0 .75rem; font:700 .7rem/1 system-ui,sans-serif; text-align:center; }
</style>
