---
import { Check, Copy, Download, Package } from "@lucide/astro";

const tokensExample = `/* Generated by https://techies.tools
   Framework: Techies Framework
   Version: 1.0.38142 · Hash: 94fe */

@layer tokens, elements, components;

@layer tokens {
  :root {
    --semantic-primary: #1d4ed8;
    --semantic-action: #2563eb;
    --semantic-surface: #ffffff;
    --semantic-text: #111827;
  }
}`;
const elementsExample = `/* Requires tokens.css loaded first.
   Generated by https://techies.tools
   Framework: Techies Framework
   Version: 1.0.38142 · Hash: 94fe */

@layer elements {
  :where(a[href]) {
    color: var(--semantic-text);
    text-decoration-line: underline;
  }
}`;
const contextExample = `---
frameworkId: techies
frameworkVersion: 1.0.38142
contentHash: 94fe
---

# Techies Framework

Load tokens.css before elements.css.
This document is self-contained and includes
the exact bytes of both CSS artifacts.`;
---

<article class="variant-a">
  <header class="variant-a__header">
    <div><p>Framework export</p><h2 id="framework-export-title">Choose a file</h2><span>Version 1.0.38142 · hash 94fe</span></div>
  </header>

  <div class="variant-a__body">
    <aside aria-label="Framework artifacts">
      <div class="variant-a__file">
        <button type="button" data-a-file="tokens" aria-selected="true">
          <i>1</i><span><strong>tokens.css</strong><small>Variables · 5.4 KB</small></span><Check size={14} />
        </button>
        <div><button type="button" data-prototype-action="Copied tokens.css"><Copy size={13} /> Copy</button><button type="button" data-prototype-action="Downloaded tokens.css"><Download size={13} /> Save</button></div>
      </div>
      <div class="variant-a__file">
        <button type="button" data-a-file="elements" aria-selected="false">
          <i>2</i><span><strong>elements.css</strong><small>Requires tokens · 8.7 KB</small></span><Check size={14} />
        </button>
        <div><button type="button" data-prototype-action="Copied elements.css"><Copy size={13} /> Copy</button><button type="button" data-prototype-action="Downloaded elements.css"><Download size={13} /> Save</button></div>
      </div>
      <div class="variant-a__file">
        <button type="button" data-a-file="context" aria-selected="false">
          <i>3</i><span><strong>context.md</strong><small>Self-contained · 31 KB</small></span><Check size={14} />
        </button>
        <div>
          <button type="button" data-prototype-action="Copied context.md"><Copy size={13} /> Copy</button>
          <button type="button" data-prototype-action="Downloaded context.md"><Download size={13} /> Save</button>
          <button class="variant-a__all" type="button" data-prototype-action="Downloaded framework.zip"><Package size={13} /> Download all</button>
        </div>
      </div>
    </aside>

    <section class="variant-a__preview">
      <div data-a-preview="tokens">
        <header><b>tokens.css</b></header>
        <pre><code>{tokensExample}</code></pre>
      </div>
      <div data-a-preview="elements" hidden>
        <header><b>elements.css</b></header>
        <div class="variant-a__warning">
          <strong>Contrast improvement available</strong>
          <button type="button" data-prototype-action="Opened contrast improvements">See improvements</button>
        </div>
        <pre><code>{elementsExample}</code></pre>
      </div>
      <div data-a-preview="context" hidden>
        <header><b>context.md</b></header>
        <pre><code>{contextExample}</code></pre>
      </div>
    </section>
  </div>
</article>

<style>
  .variant-a { min-height:610px; background:#fff; }
  .variant-a__header { border-bottom:1px solid #e5e7eb; padding:22px 64px 18px 24px; }
  .variant-a__header p,.variant-a__header h2 { margin:0; }
  .variant-a__header p { color:#667085; font-size:10px; font-weight:800; letter-spacing:.06em; text-transform:uppercase; }
  .variant-a__header h2 { margin-top:3px; font-size:20px; }
  .variant-a__header span { display:block; margin-top:4px; color:#667085; font-size:10px; }
  .variant-a__body { display:grid; grid-template-columns:290px minmax(0,1fr); min-height:520px; }
  .variant-a aside { border-right:1px solid #e5e7eb; padding:18px; background:#f8fafc; }
  .variant-a__file { margin-bottom:9px; border:1px solid #dfe3e9; border-radius:8px; background:#fff; overflow:hidden; }
  .variant-a__file > button { display:grid; grid-template-columns:24px minmax(0,1fr) 18px; align-items:center; gap:8px; width:100%; border:0; padding:10px; background:#fff; color:#111827; text-align:left; cursor:pointer; }
  .variant-a__file > button[aria-selected="true"] { background:#eaf1ff; color:#174ea6; }
  .variant-a__file > button i { display:grid; place-items:center; width:22px; height:22px; border-radius:50%; background:#eef1f5; font-size:9px; font-style:normal; font-weight:850; }
  .variant-a__file > button span { display:grid; gap:3px; }
  .variant-a__file strong { font-size:11px; }
  .variant-a__file small { color:#667085; font-size:9px; }
  .variant-a__file > div { display:grid; grid-template-columns:1fr 1fr; border-top:1px solid #edf0f3; }
  .variant-a__file > div button { display:flex; align-items:center; justify-content:center; gap:5px; height:28px; border:0; background:#fff; color:#475467; font-size:9px; font-weight:750; cursor:pointer; }
  .variant-a__file > div button + button { border-left:1px solid #edf0f3; }
  .variant-a__file > div .variant-a__all { grid-column:1 / -1; height:32px; border-top:1px solid #edf0f3; border-left:0; background:#111827; color:#fff; }
  .variant-a__preview { min-width:0; padding:18px 22px 22px; }
  .variant-a__preview header { margin-bottom:10px; }
  .variant-a__preview header b { font-size:12px; }
  .variant-a__preview pre { min-height:410px; overflow:auto; margin:0; border-radius:8px; padding:18px; background:#101828; color:#dbeafe; font:600 10px/1.65 ui-monospace,SFMono-Regular,Consolas,monospace; white-space:pre-wrap; }
  .variant-a__warning { display:grid; grid-template-columns:minmax(0,1fr) auto; align-items:center; gap:10px; margin-bottom:10px; border:1px solid #fed7aa; border-radius:7px; padding:9px; background:#fff7ed; color:#9a3412; }
  .variant-a__warning strong { font-size:9px; }
  .variant-a__warning button { width:auto; min-width:92px; height:26px; border:1px solid #fdba74; border-radius:5px; padding:0 8px; background:#fff; color:#9a3412; font-size:8px; font-weight:850; cursor:pointer; }
  @media(max-width:720px){.variant-a__body{grid-template-columns:1fr}.variant-a aside{border-right:0;border-bottom:1px solid #e5e7eb}.variant-a__header{padding-right:56px}}
</style>
