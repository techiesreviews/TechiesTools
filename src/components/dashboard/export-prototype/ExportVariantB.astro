---
import { AlertTriangle, Check, Copy, Download, Package } from "@lucide/astro";
---

<article class="variant-b">
  <header>
    <p>Framework export</p>
    <h2 id="framework-export-title">Your Framework is ready</h2>
    <span>Three synchronized files · same version and content hash</span>
  </header>

  <section class="variant-b__bundle">
    <div class="variant-b__package"><Package size={22} /></div>
    <div><strong>framework.zip</strong><span>tokens.css · elements.css · context.md</span><small>Version 1.0.38142 · 45.1 KB</small></div>
    <button type="button" data-prototype-action="Downloaded framework.zip"><Download size={15} /> Download all</button>
  </section>

  <div class="variant-b__flow" aria-label="CSS dependency order">
    <span>Load first</span><b>tokens.css</b><i>→</i><b>elements.css</b><span>Then your CSS</span>
  </div>

  <section class="variant-b__files" aria-label="Individual artifacts">
    <article>
      <div class="variant-b__file-icon">CSS</div>
      <div><strong>tokens.css</strong><span>Primitive variables and semantic roles.</span><small><Check size={11} /> Ready · 5.4 KB</small></div>
      <div class="variant-b__actions"><button type="button" aria-label="Copy tokens.css" data-prototype-action="Copied tokens.css"><Copy size={14} /></button><button type="button" aria-label="Download tokens.css" data-prototype-action="Downloaded tokens.css"><Download size={14} /></button></div>
    </article>
    <article>
      <div class="variant-b__file-icon">CSS</div>
      <div><strong>elements.css</strong><span>Active Element Treatments. Requires tokens.css.</span><small><Check size={11} /> Ready · 8.7 KB</small></div>
      <div class="variant-b__actions"><button type="button" aria-label="Copy elements.css" data-prototype-action="Copied elements.css"><Copy size={14} /></button><button type="button" aria-label="Download elements.css" data-prototype-action="Downloaded elements.css"><Download size={14} /></button></div>
      <aside><AlertTriangle size={14} /><span><strong>1 accessibility advisory</strong> Disabled button text is 4.21:1. Export can continue.</span><button type="button" data-prototype-action="Opened advisory details">Review</button></aside>
    </article>
    <article>
      <div class="variant-b__file-icon">MD</div>
      <div><strong>context.md</strong><span>AI guidance plus exact copies of both CSS files.</span><small><Check size={11} /> Self-contained · 31 KB</small></div>
      <div class="variant-b__actions"><button type="button" aria-label="Copy context.md" data-prototype-action="Copied context.md"><Copy size={14} /></button><button type="button" aria-label="Download context.md" data-prototype-action="Downloaded context.md"><Download size={14} /></button></div>
    </article>
  </section>

  <footer>
    <span>Generated by <b>https://techies.tools</b></span>
    <code>techies · v1.0.38142 · 94fe</code>
  </footer>
</article>

<style>
  .variant-b { min-height:610px; padding:26px 56px 20px 26px; background:#f7f8fa; }
  .variant-b > header { padding-right:30px; }
  .variant-b > header p,.variant-b > header h2 { margin:0; }
  .variant-b > header p { color:#667085; font-size:10px; font-weight:800; letter-spacing:.06em; text-transform:uppercase; }
  .variant-b > header h2 { margin-top:4px; font-size:22px; }
  .variant-b > header span { display:block; margin-top:5px; color:#667085; font-size:10px; }
  .variant-b__bundle { display:grid; grid-template-columns:46px minmax(0,1fr) auto; align-items:center; gap:13px; margin-top:20px; border:1px solid #c7d7fe; border-radius:11px; padding:14px; background:linear-gradient(120deg,#edf3ff,#fff); box-shadow:0 8px 24px rgb(37 99 235/.08); }
  .variant-b__package { display:grid; place-items:center; width:46px; height:46px; border-radius:10px; background:#2563eb; color:#fff; }
  .variant-b__bundle > div:nth-child(2) { display:grid; gap:3px; }
  .variant-b__bundle strong { font-size:13px; }
  .variant-b__bundle span,.variant-b__bundle small { color:#667085; font-size:9px; }
  .variant-b__bundle > button { display:flex; align-items:center; gap:6px; height:35px; border:0; border-radius:7px; padding:0 13px; background:#111827; color:#fff; font-size:10px; font-weight:800; cursor:pointer; }
  .variant-b__flow { display:flex; align-items:center; justify-content:center; gap:10px; margin:12px 0; color:#667085; font-size:9px; }
  .variant-b__flow b { border:1px solid #d7dce5; border-radius:999px; padding:5px 9px; background:#fff; color:#344054; font-size:9px; }
  .variant-b__flow i { color:#2563eb; font-size:14px; font-style:normal; }
  .variant-b__files { display:grid; gap:9px; }
  .variant-b__files > article { position:relative; display:grid; grid-template-columns:40px minmax(0,1fr) auto; align-items:center; gap:12px; min-height:73px; border:1px solid #dfe3e9; border-radius:9px; padding:11px 12px; background:#fff; }
  .variant-b__file-icon { display:grid; place-items:center; width:38px; height:38px; border-radius:7px; background:#eef2f6; color:#475467; font:850 9px/1 ui-monospace,monospace; }
  .variant-b__files > article > div:nth-child(2) { display:grid; gap:4px; }
  .variant-b__files strong { font-size:11px; }
  .variant-b__files span { color:#667085; font-size:9px; }
  .variant-b__files small { display:flex; align-items:center; gap:4px; color:#16794a; font-size:8px; font-weight:750; }
  .variant-b__actions { display:flex; gap:5px; }
  .variant-b__actions button { display:grid; place-items:center; width:31px; height:31px; border:1px solid #d7dce5; border-radius:6px; background:#fff; color:#475467; cursor:pointer; }
  .variant-b__files aside { grid-column:2 / -1; display:grid; grid-template-columns:16px minmax(0,1fr) auto; align-items:center; gap:8px; border-radius:6px; padding:7px 8px; background:#fff7ed; color:#9a3412; font-size:8px; }
  .variant-b__files aside span { color:#9a3412; }
  .variant-b__files aside button { border:0; padding:3px 5px; background:transparent; color:#9a3412; font-size:8px; font-weight:850; cursor:pointer; }
  .variant-b > footer { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-top:15px; border-top:1px solid #e1e5ea; padding-top:13px; color:#667085; font-size:9px; }
  .variant-b > footer code { font-size:8px; }
  @media(max-width:660px){.variant-b{padding:22px 20px}.variant-b__bundle{grid-template-columns:40px 1fr}.variant-b__bundle>button{grid-column:1/-1;justify-content:center}.variant-b__flow{flex-wrap:wrap}.variant-b>footer{align-items:flex-start;flex-direction:column}}
</style>
