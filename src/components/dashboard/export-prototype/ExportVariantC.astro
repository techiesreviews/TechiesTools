---
import { AlertTriangle, Check, ChevronRight, Copy, Download, Package } from "@lucide/astro";

const tokensExample = `@layer tokens, elements, components;

@layer tokens {
  :root {
    --semantic-primary: #1d4ed8;
    --semantic-action: #2563eb;
    --semantic-surface: #ffffff;
  }
}`;
const elementsExample = `/* Requires tokens.css loaded first. */
@layer elements {
  :where(button:disabled) {
    color: var(--semantic-text);
  }
}`;
const contextExample = `## Artifact manifest

- tokens.css — embedded below
- elements.css — embedded below
- context.md — this document

## Known accessibility advisories

- button/disabled contrast: 4.21:1`;
---

<article class="variant-c">
  <header>
    <p>Guided export</p>
    <h2 id="framework-export-title">Prepare your Framework</h2>
    <span>Review each artifact, then download individually or together.</span>
  </header>

  <nav class="variant-c__steps" aria-label="Export steps">
    <button type="button" data-c-step="tokens" aria-current="step"><i>1</i><span><strong>Tokens</strong><small>Foundation</small></span><Check size={13} /></button>
    <ChevronRight size={14} />
    <button type="button" data-c-step="elements" aria-current="false"><i>2</i><span><strong>Elements</strong><small>Uses Tokens</small></span><AlertTriangle size={13} /></button>
    <ChevronRight size={14} />
    <button type="button" data-c-step="context" aria-current="false"><i>3</i><span><strong>Context</strong><small>Self-contained</small></span><Check size={13} /></button>
  </nav>

  <div class="variant-c__body">
    <main>
      <section data-c-panel="tokens">
        <div class="variant-c__title"><div><p>Step 1</p><h3>Export tokens.css</h3><span>Primitive variables and semantic aliases. Load this first.</span></div><code>5.4 KB</code></div>
        <pre><code>{tokensExample}</code></pre>
        <div class="variant-c__panel-actions">
          <button type="button" data-prototype-action="Copied tokens.css"><Copy size={14} /> Copy</button>
          <button type="button" data-prototype-action="Downloaded tokens.css"><Download size={14} /> Download</button>
          <button class="variant-c__next" type="button" data-c-next="elements">Next: Elements <ChevronRight size={14} /></button>
        </div>
      </section>

      <section data-c-panel="elements" hidden>
        <div class="variant-c__title"><div><p>Step 2</p><h3>Review elements.css</h3><span>Active Element Treatments. Requires tokens.css.</span></div><code>8.7 KB</code></div>
        <aside class="variant-c__advisory">
          <AlertTriangle size={17} />
          <div><strong>Contrast advisory</strong><span>Disabled button text is 4.21:1. WCAG AA target: 4.5:1.</span><small>Export remains available. Two existing-token fixes can reach 7.12:1 or 5.08:1.</small></div>
          <button type="button" data-prototype-action="Opened two token remedies">Review fixes</button>
        </aside>
        <pre><code>{elementsExample}</code></pre>
        <div class="variant-c__panel-actions">
          <button type="button" data-prototype-action="Copied elements.css"><Copy size={14} /> Copy</button>
          <button type="button" data-prototype-action="Downloaded elements.css"><Download size={14} /> Download</button>
          <button class="variant-c__next" type="button" data-c-next="context">Continue without fix <ChevronRight size={14} /></button>
        </div>
      </section>

      <section data-c-panel="context" hidden>
        <div class="variant-c__title"><div><p>Step 3</p><h3>Export context.md</h3><span>AI guidance. Already embeds exact tokens.css and elements.css.</span></div><code>31 KB</code></div>
        <div class="variant-c__self-contained"><Check size={17} /><span><strong>Self-contained</strong> Send this file alone when an AI needs full Framework context.</span></div>
        <pre><code>{contextExample}</code></pre>
        <div class="variant-c__panel-actions">
          <button type="button" data-prototype-action="Copied context.md"><Copy size={14} /> Copy</button>
          <button type="button" data-prototype-action="Downloaded context.md"><Download size={14} /> Download</button>
        </div>
      </section>
    </main>

    <aside class="variant-c__summary">
      <p>Artifact set</p>
      <strong>Techies Framework</strong>
      <span>Version 1.0.38142</span>
      <code>content hash 94fe</code>
      <ul>
        <li><Check size={12} /> tokens.css</li>
        <li><AlertTriangle size={12} /> elements.css</li>
        <li><Check size={12} /> context.md</li>
      </ul>
      <button type="button" data-prototype-action="Downloaded framework.zip"><Package size={15} /> Download all</button>
      <small>Generated by<br /><b>https://techies.tools</b></small>
    </aside>
  </div>
</article>

<style>
