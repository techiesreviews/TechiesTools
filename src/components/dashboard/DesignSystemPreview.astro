---
import { Monitor, Smartphone, Tablet } from "@lucide/astro";
import FrameworkPreviewVariantB from "./FrameworkPreviewVariantB.prototype.astro";
import ElementReference from "./ElementReference.astro";
import { canonicalFrameworkRoute, frameworkRouteAddress, frameworkRoutes } from "../../framework/routes";

interface Props {
  primary?: string;
  fontFamily?: string;
  bodySize?: string;
  radius?: string;
  initialVariant?: "A" | "B" | "E";
}

const {
  primary = "oklch(54.6% 0.215 262.9)",
  fontFamily = "Inter",
  bodySize = "1rem",
  radius = ".5rem",
  initialVariant = "A",
} = Astro.props;
const initialRoute = frameworkRoutes.find((route) => route.variant === initialVariant) ?? canonicalFrameworkRoute("design-system")!;
const serializedFrameworkRoutes = JSON.stringify(frameworkRoutes).replaceAll("<", "\\u003c");
---

<section
  class="framework-prototype"
  aria-label="Design system preview"
  data-framework-prototype
  data-initial-variant={initialVariant}
  style={`--color-primary:${primary};--color-primary-lightest:oklch(98.9% 0.003 275.8);--color-primary-lighter:oklch(95.4% 0.019 275.5);--color-primary-light:oklch(88.3% 0.048 274.7);--color-primary-dark:oklch(40.4% 0.158 262.9);--color-primary-darker:oklch(27.3% 0.107 262.9);--color-primary-darkest:oklch(15.3% 0.06 262.9);--text-xs:.79rem;--text-s:.889rem;--text-m:1.125rem;--text-l:1.5rem;--text-xl:1.999rem;--text-2xl:2.665rem;--text-3xl:3.552rem;--text-4xl:4.735rem;--space-4xs:.402rem;--space-3xs:.482rem;--space-2xs:.579rem;--space-xs:.703rem;--space-s:.938rem;--space-m:1.25rem;--space-l:1.666rem;--space-xl:2.221rem;--space-2xl:2.961rem;--space-3xl:3.947rem;--space-4xl:5.261rem;--radius-xs:.22rem;--radius-s:.33rem;--radius-m:.5rem;--radius-l:.75rem;--radius-xl:1.13rem;--radius-full:999rem;--primary:var(--color-primary);--primary-lightest:var(--color-primary-lightest);--secondary:var(--color-primary-light);--btn-space:var(--space-3xs) var(--space-s);--fp-primary:var(--color-primary);--fp-font:${fontFamily};--fp-body-size:${bodySize};--fp-radius:var(--radius-m)`}
>
  <header class="framework-prototype__toolbar" aria-label="Preview browser controls">
    <form class="framework-prototype__address" data-prototype-address-form>
      <input
        type="text"
        value={frameworkRouteAddress(initialRoute)}
        aria-label="Preview address"
        aria-autocomplete="list"
        aria-controls="prototype-address-suggestions"
        aria-expanded="false"
        autocomplete="off"
        spellcheck="false"
        data-prototype-address
      />
      <div class="framework-prototype__suggestions" id="prototype-address-suggestions" role="listbox" hidden data-prototype-suggestions>
        {frameworkRoutes.map((route) => <button type="button" role="option" data-prototype-route={route.path}>
          <span><strong>{route.key === "homepage" ? "Homepage" : route.key === "design-system" ? "Design system" : "Elements"}</strong><small>{route.description}</small></span>
          <code>{frameworkRouteAddress(route)}</code>
        </button>)}
      </div>
    </form>

    <div class="framework-prototype__controls">
      <div class="framework-prototype__devices" aria-label="Preview viewport">
        <button class="is-active" type="button" aria-label="Desktop preview" aria-pressed="true" data-fp-device="1440">
          <Monitor size={14} stroke-width={2} />
        </button>
        <button type="button" aria-label="Tablet preview" aria-pressed="false" data-fp-device="768">
          <Tablet size={14} stroke-width={2} />
        </button>
        <button type="button" aria-label="Mobile preview" aria-pressed="false" data-fp-device="390">
          <Smartphone size={14} stroke-width={2} />
        </button>
      </div>
      <span class="framework-prototype__measure" data-fp-width>1440 px</span>
      <span class="framework-prototype__measure">100%</span>
    </div>
  </header>

  <div class="framework-prototype__inspector" aria-label="Fluid scale inspector">
    <span data-fp-min-width>320 px</span>
    <input type="range" min="320" max="1440" value="1440" step="1" aria-label="Fluid preview viewport" data-fp-viewport-slider />
    <span data-fp-max-width>1440 px</span>
    <strong data-fp-current-width>1440 px</strong>
    <i data-fp-clamp-state>Maximum clamp</i>
  </div>

  <div class="framework-prototype__scroll">
    {initialVariant === "A" && <main class="framework-prototype__page" data-fp-page data-prototype-view="A">
      <header class="framework-prototype__intro">
        <p>Current framework</p>
        <h1>Design system</h1>
        <span>Live CSS custom properties generated from the settings at left.</span>
      </header>

      <div class="framework-prototype__grid">
        <section class="fp-section" aria-labelledby="fp-colors-title">
          <header><p>01</p><h2 id="fp-colors-title">Color</h2></header>
          <div class="fp-color-grid" data-fp-colors>
            <article class="fp-color-card" style="--card-color:var(--color-primary)">
              <div class="fp-color-card__meta"><span>Primary</span><code>--color-primary</code><strong>{primary}</strong></div>
              <div class="fp-color-card__scale">{["lightest","lighter","light","","dark","darker","darkest"].map((shade) => <i style={`--shade:var(--color-primary${shade ? `-${shade}` : ""})`}></i>)}</div>
            </article>
          </div>
        </section>

        <section class="fp-section fp-section--accessibility" aria-labelledby="fp-accessibility-title">
          <header><p>02</p><h2 id="fp-accessibility-title">Semantic colors &amp; accessibility</h2></header>
          <div class="fp-semantic-grid" data-fp-semantics>
            <article class="fp-semantic-card" style="--semantic-swatch:var(--color-primary)"><span>Primary</span><code>--semantic-primary</code></article>
            <article class="fp-semantic-card" style="--semantic-swatch:var(--color-primary)"><span>Action</span><code>--semantic-action</code></article>
            <article class="fp-semantic-card" style="--semantic-swatch:var(--color-primary-lightest)"><span>Surface</span><code>--semantic-surface</code></article>
            <article class="fp-semantic-card" style="--semantic-swatch:#111827"><span>Text</span><code>--semantic-text</code></article>
            <article class="fp-semantic-card" style="--semantic-swatch:var(--color-primary-light)"><span>Border</span><code>--semantic-border</code></article>
          </div>
          <div class="fp-contrast-grid" data-fp-contrast></div>
          <div class="fp-focus-preview">
            <div><strong>Keyboard focus</strong><span>Persistent preview of the generated focus treatment.</span></div>
            <button class="btn is-focus-preview" type="button">Focused action</button>
          </div>
        </section>

        <section class="fp-section fp-section--type" aria-labelledby="fp-type-title">
          <header><p>03</p><h2 id="fp-type-title">Typography</h2></header>
          <div class="fp-type-scale" data-fp-type-scale>
            {[
              ["xs", -2, ".79", ".79"],
              ["s", -1, ".89", ".89"],
              ["m", 0, "1", "1.125"],
              ["l", 1, "1.125", "1.5"],
              ["xl", 2, "1.27", "2"],
              ["2xl", 3, "1.42", "2.66"],
              ["3xl", 4, "1.6", "3.55"],
              ["4xl", 5, "1.8", "4.74"],
            ].map(([token, step, min, max]) => (
              <article class:list={["fp-type-step", token === "m" && "is-base"]} data-type-step={step} data-type-token-name={token}>
                <header class="fp-type-step__meta">
                  <code data-type-token>--text-{token}</code>
                  <i data-type-current>{max}rem</i>
                  <span data-type-range>{min}rem → {max}rem</span>
                  {token === "m" && <strong>Base</strong>}
                </header>
                <p class="fp-type-step__sample" data-type-current-sample style={`--sample-size:var(--text-${token})`}>The quick brown fox jumps over the lazy dog.</p>
              </article>
            ))}
          </div>
        </section>

        <section class="fp-section" aria-labelledby="fp-radius-title">
          <header><p>04</p><h2 id="fp-radius-title">Border radius</h2></header>
          <div class="fp-radius-list" data-fp-radii>
            {["xs","s","m","l","xl","full"].map((token) => <article><span style={`border-radius:var(--radius-${token})`}></span><p><code>--radius-{token}</code><i>var(--radius-{token})</i></p></article>)}
          </div>
        </section>

        <section class="fp-section" aria-labelledby="fp-spacing-title">
          <header><p>05</p><h2 id="fp-spacing-title">Spacing</h2></header>
          <div class="fp-spacing-list" data-fp-spacing>
            {[["4xs",".402"],["3xs",".482"],["2xs",".579"],["xs",".703"],["s",".938"],["m","1.25"],["l","1.666"],["xl","2.221"],["2xl","2.961"],["3xl","3.947"],["4xl","5.261"]].map(([token,value]) => (
              <article style={`--space-value:var(--space-${token})`}><code>--space-{token}</code><small>{value}rem</small></article>
            ))}
          </div>
        </section>

      </div>
    </main>}
    {initialVariant === "B" && <FrameworkPreviewVariantB />}
    {initialVariant === "E" && <ElementReference />}
  </div>
</section>

<script id="framework-routes" type="application/json" set:html={serializedFrameworkRoutes} is:inline></script>

<script>
  const root = document.querySelector<HTMLElement>("[data-framework-prototype]");
  const previewPages = root?.querySelectorAll<HTMLElement>("[data-prototype-view]");
  const widthLabel = root?.querySelector<HTMLElement>("[data-fp-width]");
  const viewportSlider = root?.querySelector<HTMLInputElement>("[data-fp-viewport-slider]");
  const currentWidthLabel = root?.querySelector<HTMLElement>("[data-fp-current-width]");
  const minWidthLabel = root?.querySelector<HTMLElement>("[data-fp-min-width]");
  const maxWidthLabel = root?.querySelector<HTMLElement>("[data-fp-max-width]");
  const clampStateLabel = root?.querySelector<HTMLElement>("[data-fp-clamp-state]");
  const prototypeAddress = root?.querySelector<HTMLInputElement>("[data-prototype-address]");
  const prototypeAddressForm = root?.querySelector<HTMLFormElement>("[data-prototype-address-form]");
  const prototypeSuggestions = root?.querySelector<HTMLElement>("[data-prototype-suggestions]");
  const prototypeRoutes = Array.from(root?.querySelectorAll<HTMLButtonElement>("[data-prototype-route]") ?? []);
  let currentViewport = 1440;
  let fluidMinViewport = 320;
  let fluidMaxViewport = 1440;
  let lastType: Record<string, string> = { min:"1rem", max:"1.125rem", minRatio:"1.125", maxRatio:"1.333", minWidth:"20", maxWidth:"90" };
  let lastSpacing: {name:string;tokens:Array<{token:string;min:number;max:number}>;minWidth:number;maxWidth:number} | null = null;
  let lastRadii: {name:string;tokens:Array<{token:string;min:number;max:number}>;minWidth:number;maxWidth:number} | null = null;

  const formatRem = (value: number) => `${Number(value.toFixed(3))}rem`;
  const fluidProgress = (minWidth: number, maxWidth: number) => Math.max(0, Math.min(1, (currentViewport / 16 - minWidth) / Math.max(.0625, maxWidth - minWidth)));
  const fluidState = (progress: number) => progress <= 0 ? "minimum" : progress >= 1 ? "maximum" : "fluid";
  const syncInspector = (minWidth: number, maxWidth: number) => {
    fluidMinViewport = Math.round(minWidth * 16);
    fluidMaxViewport = Math.round(maxWidth * 16);
    if (viewportSlider) {
      viewportSlider.min = String(fluidMinViewport);
      viewportSlider.max = String(fluidMaxViewport);
      viewportSlider.value = String(Math.max(fluidMinViewport, Math.min(fluidMaxViewport, currentViewport)));
    }
    if (minWidthLabel) minWidthLabel.textContent = `${fluidMinViewport} px`;
    if (maxWidthLabel) maxWidthLabel.textContent = `${fluidMaxViewport} px`;
    if (currentWidthLabel) currentWidthLabel.textContent = `${currentViewport} px`;
    const state = currentViewport <= fluidMinViewport ? "Minimum clamp" : currentViewport >= fluidMaxViewport ? "Maximum clamp" : "Fluid";
    if (clampStateLabel) clampStateLabel.textContent = state;
    root?.setAttribute("data-fluid-state", state === "Fluid" ? "fluid" : state.startsWith("Minimum") ? "minimum" : "maximum");
  };

  const renderTypeScale = (type: Record<string, string>) => {
    lastType = type;
    const minBase = Number.parseFloat(type.min) || 1;
    const maxBase = Number.parseFloat(type.max) || 1.125;
    const minRatio = Number.parseFloat(type.minRatio) || 1.125;
    const maxRatio = Number.parseFloat(type.maxRatio) || 1.333;
    const minWidth = Number(type.minWidth) || 20;
    const maxWidth = Math.max(minWidth + .0625, Number(type.maxWidth) || 90);
    const viewportRem = currentViewport / 16;
    const progress = Math.max(0, Math.min(1, (viewportRem - minWidth) / (maxWidth - minWidth)));
    const state = fluidState(progress);
    syncInspector(minWidth, maxWidth);
    const explicitTokens = Array.isArray((type as unknown as {tokens?:unknown[]}).tokens)
      ? (type as unknown as {tokens:Array<{token:string;min:number;max:number}>}).tokens
      : [];
    const tokenSteps=[["xs",-2],["s",-1],["m",0],["l",1],["xl",2],["2xl",3],["3xl",4],["4xl",5]] as const;
    const tokenValues=explicitTokens.length ? explicitTokens : tokenSteps.map(([token,step]) => {
      const minValue=minBase*Math.pow(minRatio,step);
      return { token, min:minValue, max:Math.max(minValue,maxBase*Math.pow(maxRatio,step)) };
    });
    if (!root) return;
    const tokenByName=new Map(tokenValues.map((token) => [token.token,token]));
    tokenValues.forEach((token) => {
      const variable=`--${type.label || "text"}-${token.token}`;
      const currentValue=Number(token.min)+(Math.max(Number(token.min),Number(token.max))-Number(token.min))*progress;
      root.style.setProperty(variable,`${Number(currentValue.toFixed(3))}rem`);
    });
    root.querySelectorAll<HTMLElement>("[data-type-step]").forEach((row) => {
      const step = Number(row.dataset.typeStep ?? 0);
      const token = row.dataset.typeTokenName ?? "m";
      const variable = `--${type.label || "text"}-${token}`;
      const configured=tokenByName.get(token);
      const minValue = configured ? Number(configured.min) : minBase * Math.pow(minRatio, step);
      const maxValue = configured ? Math.max(minValue, Number(configured.max)) : Math.max(minValue, maxBase * Math.pow(maxRatio, step));
      const currentValue = minValue + (maxValue - minValue) * progress;
      const range = row.querySelector<HTMLElement>("[data-type-range]");
      const current = row.querySelector<HTMLElement>("[data-type-current]");
      const sample = row.querySelector<HTMLElement>("[data-type-current-sample]");
      const tokenLabel = row.querySelector<HTMLElement>("[data-type-token]");
      if (tokenLabel) tokenLabel.textContent = variable;
      if (current) current.textContent = `Current ${formatRem(currentValue)}`;
      row.dataset.fluidState = state;
      if (range) range.textContent = `${Number(minValue.toFixed(3))}rem → ${Number(maxValue.toFixed(3))}rem`;
      if (sample) sample.style.setProperty("--sample-size", `var(${variable})`);
    });
  };

  const escapeHtml = (value: string) => value.replace(/[&<>'"]/g, (character) => ({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"}[character] ?? character));
  const variableSlug = (value: string) => value.toLowerCase().trim().replace(/[^a-z0-9]+/g,"-").replace(/^-|-$/g,"") || "token";
  const colorSlug = (value: string) => variableSlug(value).replace(/^color-/,"").replace(/-color$/,"") || "token";
  const colorVariable = (value: string) => `--color-${colorSlug(value)}`;
  const namedColorScale = (value: string) => {
    const match=value.match(/oklch\(\s*([\d.]+)%?\s+([\d.]+)\s+([\d.]+)/i);
    const lightness=(Number(match?.[1] ?? 54.6))/(value.includes("%")?100:1);
    const chroma=Number(match?.[2] ?? .215);
    const hue=Number(match?.[3] ?? 262.9);
    const format=(level:number,relativeChroma?:number,hueOffset=0)=>{
      const chromaFactor=relativeChroma ?? Math.min(1,Math.max(.18,1-Math.abs(level-.55)/.55));
      return `oklch(${Number((level*100).toFixed(1))}% ${Number((chroma*chromaFactor).toFixed(3))} ${Number(((hue+hueOffset)%360).toFixed(1))})`;
    };
    return [format(.98892994,.01614,12.90372),format(.95380641,.08723,12.56369),format(.88273951,.22364,11.79823),value,format(lightness*.74),format(lightness*.5),format(lightness*.28)];
  };

  const oklchToRgb = (value: string): [number,number,number] | null => {
    const hex=value.trim().match(/^#([0-9a-f]{6})$/i);
    if (hex) return [Number.parseInt(hex[1].slice(0,2),16)/255,Number.parseInt(hex[1].slice(2,4),16)/255,Number.parseInt(hex[1].slice(4,6),16)/255];
    const match=value.match(/oklch\(\s*([\d.]+)%?\s+([\d.]+)\s+([\d.]+)/i);
    if (!match) return null;
    const L=Number(match[1])/(value.includes("%")?100:1), C=Number(match[2]), h=Number(match[3])*Math.PI/180;
    const a=C*Math.cos(h), b=C*Math.sin(h);
    const l_=L+.3963377774*a+.2158037573*b, m_=L-.1055613458*a-.0638541728*b, s_=L-.0894841775*a-1.291485548*b;
    const l=l_**3, m=m_**3, s=s_**3;
    const linear=[4.0767416621*l-3.3077115913*m+.2309699292*s,-1.2684380046*l+2.6097574011*m-.3413193965*s,-.0041960863*l-.7034186147*m+1.707614701*s];
    return linear.map((channel)=>Math.max(0,Math.min(1,channel<=.0031308?12.92*channel:1.055*channel**(1/2.4)-.055))) as [number,number,number];
  };
  const luminance = (rgb: [number,number,number]) => rgb.map((channel)=>channel<=.04045?channel/12.92:((channel+.055)/1.055)**2.4).reduce((sum,channel,index)=>sum+channel*[.2126,.7152,.0722][index],0);
  const contrastRatio = (foregroundValue: string, backgroundValue: string) => {
    const foreground=oklchToRgb(foregroundValue), background=oklchToRgb(backgroundValue);
    if (!foreground || !background) return 1;
    const foregroundLuminance=luminance(foreground), backgroundLuminance=luminance(background);
    return (Math.max(foregroundLuminance,backgroundLuminance)+.05)/(Math.min(foregroundLuminance,backgroundLuminance)+.05);
  };
  type SemanticMapping = { role:string; reference:string; value:string; label:string; variable:string };

  const renderSemanticMappings = (semantics: Record<string,SemanticMapping>) => {
    if (!root) return;
    const roles=["primary","action","surface","text","border","focus"];
    roles.forEach((role) => {
      const mapping=semantics[role];
      if (mapping) {
        const value=mapping.reference.startsWith("--")?`var(${mapping.reference})`:mapping.value;
        root.style.setProperty(mapping.variable,value);
        root.style.setProperty(`--semantic-${role}`,value);
      }
    });
    const semanticContainer=root.querySelector<HTMLElement>("[data-fp-semantics]");
    if (semanticContainer) semanticContainer.innerHTML=roles.map((role)=>{
      const mapping=semantics[role];
      if (!mapping) return "";
      return `<article class="fp-semantic-card" style="--semantic-swatch:var(--semantic-${role})"><i></i><span>${role[0].toUpperCase()+role.slice(1)}</span><code>${mapping.variable}</code><small>${escapeHtml(mapping.label)}</small></article>`;
    }).join("");
    const contrastContainer=root.querySelector<HTMLElement>("[data-fp-contrast]");
    if (!contrastContainer) return;
    const pairs=[
      ["Text on surface","text","surface","text"],
      ["Action on surface","action","surface","ui"],
      ["Focus on surface","focus","surface","ui"],
      ["Border on surface","border","surface","ui"],
    ] as const;
    contrastContainer.innerHTML=pairs.map(([label,foregroundRole,backgroundRole,kind])=>{
      const foreground=semantics[foregroundRole], background=semantics[backgroundRole];
      if (!foreground || !background) return "";
      const ratio=contrastRatio(foreground.value,background.value);
      const passes=kind==="text"?ratio>=7:ratio>=3;
      const rating=kind==="text"?(ratio>=7?"AAA":ratio>=4.5?"AAA large":"Fail"):(ratio>=3?"UI AA":"Fail");
      const className=passes?(kind==="text"?"is-aaa":"is-ui"):ratio>=4.5?"is-large":"is-fail";
      return `<article class="fp-contrast-card"><i style="--contrast-background:${background.value};--contrast-foreground:${foreground.value}"><b>Aa</b></i><div><strong>${label}</strong><p><span class="fp-contrast-badge ${className}">${ratio.toFixed(2)}:1 · ${rating}</span></p><small>${escapeHtml(foreground.label)} / ${escapeHtml(background.label)}</small></div></article>`;
    }).join("");
  };

  const renderSemantics = (colors: Array<{name:string;value:string;scale:string[];variable:string}>) => {
    const primary=colors[0];
    if (!primary) return;
    const variable=primary.variable;
    const scale=namedColorScale(primary.value);
    renderSemanticMappings({
      primary:{role:"primary",reference:variable,value:primary.value,label:`${primary.name} / Base`,variable:"--semantic-primary"},
      action:{role:"action",reference:variable,value:primary.value,label:`${primary.name} / Base`,variable:"--semantic-action"},
      surface:{role:"surface",reference:`${variable}-lightest`,value:scale[0],label:`${primary.name} / Lightest`,variable:"--semantic-surface"},
      text:{role:"text",reference:"oklch(0% 0 0)",value:"oklch(0% 0 0)",label:"Black",variable:"--semantic-text"},
      border:{role:"border",reference:`${variable}-light`,value:scale[2],label:`${primary.name} / Light`,variable:"--semantic-border"},
      focus:{role:"focus",reference:variable,value:primary.value,label:`${primary.name} / Base`,variable:"--semantic-focus"},
    });
  };

  const renderColors = (colors: Array<{name:string;value:string;scale:string[];variable:string}>) => {
    if (!root) return;
    const container = root.querySelector<HTMLElement>("[data-fp-colors]");
    colors.forEach((color) => {
      const variable=color.variable;
      const scale=namedColorScale(color.value);
      root.style.setProperty(variable,color.value);
      const shades=[["lightest",scale[0]],["lighter",scale[1]],["light",scale[2]],["dark",scale[4]],["darker",scale[5]],["darkest",scale[6]]];
      shades.forEach(([name,shade])=>root.style.setProperty(`${variable}-${name}`,shade));
    });
    if (container) container.innerHTML = colors.map((color) => {
      const variable=color.variable;
      const scaleVariables=[`${variable}-lightest`,`${variable}-lighter`,`${variable}-light`,variable,`${variable}-dark`,`${variable}-darker`,`${variable}-darkest`];
      return `<article class="fp-color-card" style="--card-color:var(${variable})"><div class="fp-color-card__meta"><span>${escapeHtml(color.name)}</span><code>${variable}</code><strong>${color.value}</strong></div><div class="fp-color-card__scale">${scaleVariables.map((name) => `<i style="--shade:var(${name})"></i>`).join("")}</div></article>`;
    }).join("");
    renderSemantics(colors);
  };

  const renderSpacing = (spacing: {name:string;tokens:Array<{token:string;min:number;max:number}>;minWidth:number;maxWidth:number}) => {
    lastSpacing = spacing;
    if (!root) return;
    const container = root.querySelector<HTMLElement>("[data-fp-spacing]");
    const progress = fluidProgress(spacing.minWidth, spacing.maxWidth);
    const state = fluidState(progress);
    syncInspector(spacing.minWidth, spacing.maxWidth);
    const values = spacing.tokens.map((token) => token.min + (token.max - token.min) * progress);
    spacing.tokens.forEach((token, index) => root.style.setProperty(`--${variableSlug(spacing.name)}-${token.token}`,`${Number(values[index].toFixed(3))}rem`));
    if (container) container.innerHTML = spacing.tokens.map((token, index) => {
      const value=Number(values[index].toFixed(3));
      const variable=`--${variableSlug(spacing.name)}-${token.token}`;
      return `<article data-fluid-state="${state}" style="--space-value:var(${variable})"><code>${variable}</code><strong>${value}rem</strong><small>${formatRem(token.min)} &rarr; ${formatRem(token.max)}</small></article>`;
    }).join("");
  };

  const renderRadii = (radii: {name:string;tokens:Array<{token:string;min:number;max:number}>;minWidth:number;maxWidth:number}) => {
    lastRadii = radii;
    if (!root) return;
    const container = root.querySelector<HTMLElement>("[data-fp-radii]");
    const progress = fluidProgress(radii.minWidth, radii.maxWidth);
    const state = fluidState(progress);
    syncInspector(radii.minWidth, radii.maxWidth);
    radii.tokens.forEach((token) => {
      const value=Number((token.min+(token.max-token.min)*progress).toFixed(3));
      root.style.setProperty(`--${variableSlug(radii.name)}-${token.token}`,`${value}rem`);
    });
    if (container) container.innerHTML = radii.tokens.map((token) => {
      const value=Number((token.min+(token.max-token.min)*progress).toFixed(3));
      const variable=`--${variableSlug(radii.name)}-${token.token}`;
      return `<article data-fluid-state="${state}"><span style="border-radius:var(${variable})"></span><p><code>${variable}</code><strong>${value}rem</strong><i>${formatRem(token.min)} &rarr; ${formatRem(token.max)}</i></p></article>`;
    }).join("");
  };

  renderSemantics([{name:"Primary",value:"oklch(54.6% 0.215 262.9)",scale:["oklch(96% 0.215 262.9)","oklch(86% 0.215 262.9)","oklch(54.6% 0.215 262.9)","oklch(39.3% 0.215 262.9)","oklch(27.3% 0.215 262.9)"],variable:"--color-primary"}]);

  const setViewport = (width: number) => {
      currentViewport = Math.round(width);
      root?.querySelectorAll<HTMLButtonElement>("[data-fp-device]").forEach((item) => {
        const active = Number(item.dataset.fpDevice) === currentViewport;
        item.classList.toggle("is-active", active);
        item.setAttribute("aria-pressed", String(active));
      });
      previewPages?.forEach((previewPage) => previewPage.style.setProperty("--fp-viewport", `${currentViewport}px`));
      if (widthLabel) widthLabel.textContent = `${currentViewport} px`;
      syncInspector(fluidMinViewport / 16, fluidMaxViewport / 16);
      renderTypeScale(lastType);
      if (lastSpacing) renderSpacing(lastSpacing);
      if (lastRadii) renderRadii(lastRadii);
  };

  root?.querySelectorAll<HTMLButtonElement>("[data-fp-device]").forEach((button) => {
    button.addEventListener("click", () => {
      setViewport(Number(button.dataset.fpDevice ?? 1440));
    });
  });

  viewportSlider?.addEventListener("input", () => setViewport(Number(viewportSlider.value)));

  type Route = { key:string; path:string; variant:string; title:string; description:string; address:string };
  const routes = (JSON.parse(document.querySelector<HTMLScriptElement>("#framework-routes")?.textContent ?? "[]") as Omit<Route, "address">[])
    .map((route) => ({ ...route, address: `techies.local${route.path}` }));
  let currentVariant = root?.dataset.initialVariant ?? "A";
  let activeRouteIndex = -1;
  const routeForVariant = (variant: string) => routes.find((route) => route.variant === variant) ?? routes[0];
  const variantForAddress = (value: string) => {
    const normalized = value.trim().toLowerCase().replace(/^https?:\/\//, "").replace(/\/$/, "");
    const path = normalized.replace(/^techies\.local/, "");
    return routes.find((route) => route.address === normalized || route.path === path)?.variant ?? null;
  };
  const closeAddressSuggestions = () => {
    if (!prototypeSuggestions || !prototypeAddress) return;
    prototypeSuggestions.hidden = true;
    prototypeAddress.setAttribute("aria-expanded", "false");
    activeRouteIndex = -1;
    prototypeRoutes.forEach((route) => route.classList.remove("is-active"));
  };
  const filterAddressSuggestions = (showAll = false) => {
    if (!prototypeSuggestions || !prototypeAddress) return;
    const query = prototypeAddress.value.trim().toLowerCase();
    let visible = 0;
    prototypeRoutes.forEach((route) => {
      const match = showAll || !query || `${route.dataset.prototypeRoute} ${route.textContent}`.toLowerCase().includes(query);
      route.hidden = !match;
      if (match) visible += 1;
    });
    prototypeSuggestions.hidden = visible === 0;
    prototypeAddress.setAttribute("aria-expanded", String(visible > 0));
  };
  const activateRoute = (button: HTMLButtonElement | undefined) => {
    if (!button) return;
    const path = button.dataset.prototypeRoute;
    if (path) window.location.assign(path);
    closeAddressSuggestions();
    prototypeAddress?.blur();
  };
  const renderPrototypeVariant = (requested: string) => {
    const variant = routes.find((item) => item.variant === requested) ?? routes[0];
    currentVariant = variant.variant;
    previewPages?.forEach((previewPage) => { previewPage.hidden = previewPage.dataset.prototypeView !== currentVariant; });
    if (prototypeAddress) prototypeAddress.value = routeForVariant(variant.variant).address;
  };
  prototypeAddress?.addEventListener("focus", () => {
    prototypeAddress.select();
    filterAddressSuggestions(true);
  });
  prototypeAddress?.addEventListener("click", () => filterAddressSuggestions(true));
  prototypeAddress?.addEventListener("input", () => filterAddressSuggestions());
  prototypeAddress?.addEventListener("keydown", (event) => {
    const visibleRoutes = prototypeRoutes.filter((route) => !route.hidden);
    if (event.key === "Escape") {
      closeAddressSuggestions();
      prototypeAddress.value = routeForVariant(currentVariant).address;
      prototypeAddress.blur();
      return;
    }
    if (event.key === "Enter") {
      event.preventDefault();
      const selected = activeRouteIndex >= 0 ? visibleRoutes[activeRouteIndex] : undefined;
      const requestedVariant = variantForAddress(prototypeAddress.value);
      if (selected) activateRoute(selected);
      else if (requestedVariant) window.location.assign(routeForVariant(requestedVariant).path);
      else prototypeAddress.value = routeForVariant(currentVariant).address;
      closeAddressSuggestions();
      prototypeAddress.blur();
      return;
    }
    if (event.key !== "ArrowDown" && event.key !== "ArrowUp") return;
    event.preventDefault();
    if (!visibleRoutes.length) return;
    activeRouteIndex = (activeRouteIndex + (event.key === "ArrowDown" ? 1 : -1) + visibleRoutes.length) % visibleRoutes.length;
    prototypeRoutes.forEach((route) => route.classList.remove("is-active"));
    visibleRoutes[activeRouteIndex]?.classList.add("is-active");
    visibleRoutes[activeRouteIndex]?.scrollIntoView({block:"nearest"});
  });
  prototypeAddressForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const visibleRoutes = prototypeRoutes.filter((route) => !route.hidden);
    const selected = activeRouteIndex >= 0 ? visibleRoutes[activeRouteIndex] : undefined;
    const requestedVariant = variantForAddress(prototypeAddress?.value ?? "");
    if (selected) activateRoute(selected);
    else if (requestedVariant) window.location.assign(routeForVariant(requestedVariant).path);
    else if (prototypeAddress) prototypeAddress.value = routeForVariant(currentVariant).address;
    closeAddressSuggestions();
  });
  prototypeRoutes.forEach((route) => route.addEventListener("pointerdown", (event) => {
    event.preventDefault();
    activateRoute(route);
  }));
  document.addEventListener("pointerdown", (event) => {
    if (!prototypeAddressForm?.contains(event.target as Node)) closeAddressSuggestions();
  });
  renderPrototypeVariant(currentVariant);

  window.addEventListener("framework-preview:update", (event) => {
    if (!root) return;
    const detail = (event as CustomEvent).detail;
    if (!detail) return;
    if (detail.variables) Object.entries(detail.variables).forEach(([name, value]) => root.style.setProperty(name, String(value)));
    if (detail.primary) {
      root.style.setProperty("--fp-primary", detail.primary);
    }
    if (detail.colors) renderColors(detail.colors);
    if (detail.semantics) renderSemanticMappings(detail.semantics);
    if (detail.spacing) renderSpacing(detail.spacing);
    if (detail.radii) renderRadii(detail.radii);
    if (detail.type?.family) root.style.setProperty("--fp-font", detail.type.family);
    if (detail.type) renderTypeScale(detail.type);
    const size = detail.type?.min?.match?.(/[\d.]+\s*rem/i)?.[0];
    if (size) {
      root.style.setProperty("--fp-body-size", size.replace(/\s+/g, ""));
      root.querySelectorAll<HTMLElement>("[data-fp-body-size]").forEach((item) => item.textContent = size);
    }
    if (detail.radius) {
      root.style.setProperty("--fp-radius", detail.radius);
      root.querySelectorAll<HTMLElement>("[data-fp-radius]").forEach((item) => item.textContent = detail.radius);
    }
  });
</script>

