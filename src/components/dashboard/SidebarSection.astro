---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="sidebar-section" aria-labelledby={`${title.toLowerCase()}-nav-label`}>
  <h2 class="sidebar-section__title" id={`${title.toLowerCase()}-nav-label`}>{title}</h2>
  <div class="sidebar-section__items">
    <slot />
  </div>
</section>

<style>
  .sidebar-section {
    display: grid;
    gap: 0.375rem;
    inline-size: 100%;
  }

  .sidebar-section__title {
    margin: 0;
    color: var(--sidebar-muted);
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1.2;
    transition: opacity 160ms ease;
  }

  .sidebar-section__items {
    display: grid;
    gap: 0.375rem;
    inline-size: 100%;
  }
</style>
