---
import AppSidebar from "./AppSidebar.astro";
import FrameworkSidebar from "./FrameworkSidebar.astro";
---

<div class="dashboard-shell">
  <div class="dashboard-shell__rail">
    <AppSidebar />
    <FrameworkSidebar />
  </div>
  <main class="dashboard-shell__main">
    <slot />
  </main>
</div>

<style>
  .dashboard-shell {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    min-block-size: 100vh;
    max-block-size: 100vh;
    overflow: hidden;
    background: var(--background);
  }

  .dashboard-shell__rail {
    display: grid;
    grid-template-columns: auto auto;
    min-block-size: 0;
    box-shadow: 1px 0 0 var(--sidebar-border);
  }

  .dashboard-shell__main {
    min-inline-size: 0;
    min-block-size: 0;
    overflow: hidden;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  @media (max-width: 720px) {
    .dashboard-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
