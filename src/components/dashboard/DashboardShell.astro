---
import AppSidebar from "./AppSidebar.astro";
import FrameworkSettingsBar from "./FrameworkSettingsBar.astro";
import { getCollection } from "astro:content";
import { buildElementCatalog } from "../../framework/catalog/index";
import { treatmentModules } from "../../framework/treatments/index";
const elementGuidance = (await getCollection("elements")).map((entry) => ({ id: entry.id, ...entry.data }));
const starterTokenRegistry = new Map([
  ...["semantic.primary", "semantic.action", "semantic.surface", "semantic.text", "semantic.border", "semantic.focus"].map((id) => [id, "color"] as const),
  ...["spacing.3xs", "spacing.s"].map((id) => [id, "dimension"] as const),
  ...["typography.m", "radius.m"].map((id) => [id, "dimension"] as const),
]);
const catalog = buildElementCatalog({ guidance: elementGuidance, treatments: treatmentModules, tokens: starterTokenRegistry });
if (!catalog.success) throw new Error(catalog.diagnostics.map((item) => `${item.code}: ${item.message}`).join("\n"));
const serializedElementGuidance = JSON.stringify(elementGuidance).replaceAll("<", "\\u003c");
---

<div class="dashboard-shell">
  <div class="dashboard-shell__rail">
    <AppSidebar />
    <div class="dashboard-shell__settings">
      <FrameworkSettingsBar />
    </div>
  </div>
  <main class="dashboard-shell__main" data-framework-preview>
    <slot />
  </main>
</div>

<script id="framework-element-guidance" type="application/json" data-element-guidance set:html={serializedElementGuidance} is:inline></script>
<script>
  import "../../framework/controller/browser.ts";
</script>

<style>
  .dashboard-shell {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    min-block-size: 100vh;
    max-block-size: 100vh;
    overflow: hidden;
    background: var(--background);
  }

  .dashboard-shell__rail {
    display: grid;
    grid-template-columns: auto auto;
    min-block-size: 0;
    box-shadow: 1px 0 0 var(--sidebar-border);
  }

  .dashboard-shell__settings {
    min-block-size: 0;
    block-size: 100vh;
    overflow: hidden;
    background: #fafbfc;
  }

  .dashboard-shell__main {
    min-inline-size: 0;
    min-block-size: 0;
    overflow: hidden;
    padding: 0;
  }


  @media (max-width: 720px) {
    .dashboard-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
