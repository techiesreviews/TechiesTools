---
// PROTOTYPE — Three export-dialog variants, switchable with ?variant=A|B|C.
import { Download, X } from "@lucide/astro";
import ExportVariantA from "./export-prototype/ExportVariantA.astro";
import ExportVariantB from "./export-prototype/ExportVariantB.astro";
import ExportVariantC from "./export-prototype/ExportVariantC.astro";
import PrototypeSwitcher from "./export-prototype/PrototypeSwitcher.astro";

const prototypeEnabled = import.meta.env.DEV;
---

<div class="framework-export" data-framework-export-prototype>
  <div class="framework-export__bar">
    <button class="framework-export__open" type="button" data-export-open>Export</button>
    <button class="framework-export__direct" type="button" aria-label="Open Framework export" title="Open Framework export" data-export-open>
      <Download size={14} stroke-width={2} />
    </button>
  </div>

  <dialog class="framework-export__dialog" aria-labelledby="framework-export-title" data-export-dialog>
    <div class="framework-export__surface">
      <button class="framework-export__close" type="button" aria-label="Close export" data-export-close>
        <X size={16} stroke-width={2} />
      </button>

      <section data-prototype-variant="A">
        <ExportVariantA />
      </section>
      <section data-prototype-variant="B" hidden>
        <ExportVariantB />
      </section>
      <section data-prototype-variant="C" hidden>
        <ExportVariantC />
      </section>

      <p class="framework-export__feedback" aria-live="polite" data-prototype-feedback></p>
    </div>
    {prototypeEnabled && <PrototypeSwitcher />}
  </dialog>
</div>

<script>
  const root = document.querySelector<HTMLElement>("[data-framework-export-prototype]");
  const dialog = root?.querySelector<HTMLDialogElement>("[data-export-dialog]");
  const variants = ["A", "B", "C"] as const;
  type Variant = typeof variants[number];

  const selectedVariant = (): Variant => {
    const value = new URL(window.location.href).searchParams.get("variant")?.toUpperCase();
    return variants.includes(value as Variant) ? value as Variant : "A";
  };

  const renderVariant = (variant: Variant) => {
    root?.querySelectorAll<HTMLElement>("[data-prototype-variant]").forEach((section) => {
      section.hidden = section.dataset.prototypeVariant !== variant;
    });
    root?.querySelectorAll<HTMLElement>("[data-prototype-switcher-label]").forEach((label) => {
      const names = { A: "Artifact checklist", B: "Bundle overview", C: "Guided sequence" };
      label.textContent = `${variant} — ${names[variant]}`;
    });
  };

  const chooseVariant = (offset: number) => {
    const current = selectedVariant();
    const next = variants[(variants.indexOf(current) + offset + variants.length) % variants.length];
    const url = new URL(window.location.href);
    url.searchParams.set("variant", next);
    window.history.replaceState({}, "", url);
    renderVariant(next);
  };

  renderVariant(selectedVariant());
  root?.querySelectorAll("[data-export-open]").forEach((button) => button.addEventListener("click", () => dialog?.showModal()));
  root?.querySelector("[data-export-close]")?.addEventListener("click", () => dialog?.close());
  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) dialog.close();
  });
  root?.querySelector("[data-prototype-previous]")?.addEventListener("click", () => chooseVariant(-1));
  root?.querySelector("[data-prototype-next]")?.addEventListener("click", () => chooseVariant(1));

  window.addEventListener("keydown", (event) => {
    if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
    const target = event.target;
    if (target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || (target instanceof HTMLElement && target.isContentEditable)) return;
    chooseVariant(event.key === "ArrowLeft" ? -1 : 1);
  });

  root?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const action = target.closest<HTMLElement>("[data-prototype-action]");
    if (action) {
      const feedback = root.querySelector<HTMLElement>("[data-prototype-feedback]");
      if (feedback) feedback.textContent = action.dataset.prototypeAction ?? "Prototype action";
      window.setTimeout(() => { if (feedback) feedback.textContent = ""; }, 1800);
    }

    const file = target.closest<HTMLElement>("[data-a-file]");
    if (file) {
      const id = file.dataset.aFile;
      root.querySelectorAll<HTMLElement>("[data-a-file]").forEach((item) => item.setAttribute("aria-selected", String(item === file)));
      root.querySelectorAll<HTMLElement>("[data-a-preview]").forEach((item) => item.hidden = item.dataset.aPreview !== id);
    }

    const step = target.closest<HTMLElement>("[data-c-step]");
    if (step) {
      const id = step.dataset.cStep;
      root.querySelectorAll<HTMLElement>("[data-c-step]").forEach((item) => item.setAttribute("aria-current", item === step ? "step" : "false"));
      root.querySelectorAll<HTMLElement>("[data-c-panel]").forEach((item) => item.hidden = item.dataset.cPanel !== id);
    }

    const nextStep = target.closest<HTMLElement>("[data-c-next]");
    if (nextStep) {
      root.querySelector<HTMLElement>(`[data-c-step="${nextStep.dataset.cNext}"]`)?.click();
    }
  });
</script>

<style>
  .framework-export { z-index:4; padding:10px 0 0; background:#fafbfc; }
  .framework-export__bar { display:grid; grid-template-columns:minmax(0,1fr) 34px; gap:6px; }
  .framework-export__open { width:100%; height:32px; border:0; border-radius:6px; background:#111827; color:#fff; font-size:11px; font-weight:800; cursor:pointer; }
  .framework-export__direct { display:grid; place-items:center; width:34px; height:32px; border:1px solid #d7dce5; border-radius:6px; background:#fff; color:#596274; cursor:pointer; }
  .framework-export__dialog { width:min(880px,calc(100vw - 32px)); max-height:min(780px,calc(100vh - 32px)); border:0; border-radius:14px; padding:0; background:transparent; }
  .framework-export__dialog::backdrop { background:rgb(17 24 39/.48); backdrop-filter:blur(2px); }
  .framework-export__surface { position:relative; max-height:min(780px,calc(100vh - 32px)); overflow:auto; border:1px solid #d7dce5; border-radius:14px; background:#fff; box-shadow:0 28px 90px rgb(15 23 42/.28); color:#111827; }
  .framework-export__close { position:absolute; z-index:4; top:16px; right:16px; display:grid; place-items:center; width:32px; height:32px; border:1px solid #e2e6ec; border-radius:7px; background:#fff; color:#667085; cursor:pointer; }
  .framework-export__close:hover,.framework-export__close:focus-visible { border-color:#2563eb; outline:0; color:#2563eb; }
  .framework-export__feedback { position:fixed; z-index:8; left:50%; bottom:78px; min-width:180px; margin:0; border-radius:999px; padding:0; background:#111827; color:#fff; font-size:11px; font-weight:750; text-align:center; transform:translateX(-50%); }
  .framework-export__feedback:not(:empty) { padding:9px 14px; box-shadow:0 10px 30px rgb(15 23 42/.24); }
</style>
