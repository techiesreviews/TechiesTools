---
import { ChevronRight, CircleHelp } from "@lucide/astro";

interface Props {
  kind: "type" | "actions" | "form" | "table" | "figure" | "disclosure" | "dialog";
  idPrefix: string;
}

const { kind, idPrefix } = Astro.props;
const checkId = `${idPrefix}-${kind}-contrast`;
const tooltipId = `${checkId}-tooltip`;
---

<div class="element-specimen" data-element-specimen={kind}>
  <div class="element-specimen__check">
    <button type="button" aria-label="Open accessibility check" aria-describedby={tooltipId} popovertarget={checkId}>?</button>
    <span id={tooltipId} role="tooltip">Manual contrast check required</span>
    <div class="element-specimen__popover" id={checkId} popover>
      <header><strong>Accessibility check</strong><span>Text on surface</span></header>
      <div><i style="--swatch:var(--semantic-text,#111827)"></i><code>semantic.text</code><ChevronRight size={13} /><i style="--swatch:var(--semantic-surface,#fff)"></i><code>semantic.surface</code></div>
      <p><CircleHelp size={14} /> Ratio not measured. Manual verification required.</p>
      <small>Token swatches are contextual evidence only. Do not infer AA or AAA conformance until declared and computed colors agree.</small>
    </div>
  </div>

  {kind === "type" && (
    <div class="element-specimen__type">
      <h2>Clear guidance creates coherent interfaces</h2>
      <p>Paragraphs explain one idea at a comfortable reading width. Strong text marks important meaning without replacing hierarchy.</p>
      <blockquote>“Default treatments make ordinary generation predictable.” <cite>Framework guidance</cite></blockquote>
    </div>
  )}

  {kind === "actions" && (
    <div class="element-specimen__actions">
      <a href={`#${idPrefix.replace(/^element-/, "")}`}>Read guidance</a>
      <button class="btn" type="button">Save preference</button>
      <button class="btn ghost" type="button">Compare option</button>
    </div>
  )}

  {kind === "form" && (
    <form class="element-specimen__form" onsubmit="return false">
      <label for={`${idPrefix}-email`}>Email address</label>
      <input id={`${idPrefix}-email`} type="email" value="name@example.com" aria-describedby={`${idPrefix}-email-help`} />
      <small id={`${idPrefix}-email-help`}>Used only for project notifications.</small>
      <label for={`${idPrefix}-project`}>Project type</label>
      <select id={`${idPrefix}-project`}><option>Marketing website</option><option>Web application</option></select>
      <p role="alert">Example error: choose a valid delivery date.</p>
    </form>
  )}

  {kind === "table" && (
    <div class="element-specimen__table-wrap">
      <table>
        <caption>Framework export formats</caption>
        <thead><tr><th scope="col">Format</th><th scope="col">Purpose</th><th scope="col">Status</th></tr></thead>
        <tbody><tr><th scope="row">Markdown</th><td>AI context</td><td>Planned</td></tr><tr><th scope="row">CSS</th><td>Implementation</td><td>Ready</td></tr></tbody>
      </table>
    </div>
  )}

  {kind === "figure" && (
    <figure class="element-specimen__figure">
      <div role="img" aria-label="Abstract blue framework scale illustration"><span></span><span></span><span></span><span></span></div>
      <figcaption>Figure captions explain why media matters, not merely what it shows.</figcaption>
    </figure>
  )}

 {kind === "disclosure" && (
   <div class="element-specimen__disclosure">
     <details open><summary>When should guidance be overridden?</summary><p>Only during an explicit Exploration or when the person directly requests an exception.</p></details>
    </div>
  )}

  {kind === "dialog" && (
    <div class="element-specimen__disclosure">
     <button class="btn ghost" type="button" data-open-element-dialog={`${idPrefix}-dialog`}>Open dialog example</button>
     <dialog id={`${idPrefix}-dialog`}><h3>Confirm Promotion</h3><p>Promote selected treatment into production guidance?</p><form method="dialog"><button class="btn ghost">Cancel</button><button class="btn">Promote</button></form></dialog>
    </div>
  )}
</div>

<style>
  .element-specimen { position:relative; min-width:0; color:var(--semantic-text,#111827); font-family:var(--fp-font),system-ui,sans-serif; }
  .element-specimen__check { position:absolute; z-index:4; inset:.65rem .65rem auto auto; }
  .element-specimen__check > button { display:grid; place-items:center; width:1.8rem; height:1.8rem; border:1px solid color-mix(in oklch,var(--semantic-action,var(--primary)) 35%,white); border-radius:999px; background:var(--semantic-surface,#fff); color:var(--semantic-action,var(--primary)); font:800 .62rem/1 system-ui,sans-serif; cursor:pointer; }
  .element-specimen__check > span { position:absolute; inset:auto 0 calc(100% + .4rem) auto; display:none; width:max-content; max-width:13rem; border-radius:.35rem; padding:.38rem .5rem; background:#111827; color:white; font:600 .65rem/1.3 system-ui,sans-serif; }
  .element-specimen__check:has(> button:hover) > span,.element-specimen__check:has(> button:focus-visible) > span { display:block; }
  .element-specimen__popover { width:min(22rem,calc(100vw - 2rem)); border:1px solid #d7dce5; border-radius:var(--radius-m); padding:var(--space-s); background:white; color:#111827; box-shadow:0 1.25rem 3rem rgb(15 23 42/.24); font-family:system-ui,sans-serif; }
  .element-specimen__popover::backdrop { background:rgb(15 23 42/.16); }
  .element-specimen__popover header { display:flex; justify-content:space-between; gap:1rem; margin-bottom:.75rem; }
  .element-specimen__popover header span,.element-specimen__popover small { color:#697386; font-size:.72rem; }
  .element-specimen__popover > div { display:grid; grid-template-columns:1.5rem 1fr auto 1.5rem 1fr; align-items:center; gap:.4rem; }
  .element-specimen__popover i { width:1.5rem; height:1.5rem; border:1px solid #d7dce5; border-radius:.3rem; background:var(--swatch); }
  .element-specimen__popover code { font-size:.68rem; }
  .element-specimen__popover p { display:flex; align-items:center; gap:.35rem; margin:.75rem 0 .35rem; color:#166534; font-size:.78rem; font-weight:700; }
  .element-specimen__type { display:grid; gap:var(--space-s); max-width:48rem; padding:var(--space-xl); }
  .element-specimen__type h2,.element-specimen__type p,.element-specimen__type blockquote { margin:0; }
  .element-specimen__type h2 { max-width:20ch; font-size:var(--text-xl); line-height:1.08; }
  .element-specimen__type p { max-width:62ch; font-size:var(--text-m); line-height:1.55; }
  .element-specimen__type blockquote { border-left:.25rem solid var(--semantic-action,var(--primary)); padding-left:var(--space-m); font-size:var(--text-l); }
  .element-specimen__type cite { display:block; margin-top:var(--space-xs); font-size:var(--text-s); font-style:normal; }
  .element-specimen__actions { display:flex; flex-wrap:wrap; align-items:center; gap:var(--space-s); padding:var(--space-xl); }
  .element-specimen__actions a { color:var(--semantic-action,var(--primary)); font-weight:700; text-underline-offset:.2em; }
  .element-specimen__form { display:grid; grid-template-columns:minmax(0,1fr) minmax(0,1fr); gap:var(--space-xs) var(--space-m); padding:var(--space-xl); }
  .element-specimen__form label { font-weight:750; }
  .element-specimen__form input,.element-specimen__form select { min-width:0; min-height:2.65rem; border:1px solid var(--semantic-border,#cbd5e1); border-radius:var(--radius-s); padding:0 var(--space-s); background:white; color:inherit; font:inherit; }
  .element-specimen__form small,.element-specimen__form p { margin:0; font-size:var(--text-s); }
  .element-specimen__form p { grid-column:1/-1; border-left:.2rem solid #dc2626; padding-left:var(--space-xs); color:#991b1b; }
  .element-specimen__table-wrap { overflow:auto; padding:var(--space-xl); }
  .element-specimen table { width:100%; border-collapse:collapse; font-size:var(--text-s); }
  .element-specimen caption { margin-bottom:var(--space-s); font-weight:800; text-align:left; }
  .element-specimen th,.element-specimen td { border-bottom:1px solid var(--semantic-border,#cbd5e1); padding:var(--space-xs); text-align:left; }
  .element-specimen thead { background:var(--primary-lightest,#eff6ff); }
  .element-specimen__figure { margin:0; }
  .element-specimen__figure > div { display:grid; grid-template-columns:repeat(4,1fr); align-items:end; gap:var(--space-xs); min-height:11rem; padding:var(--space-xl); background:var(--primary-lightest,#eff6ff); }
  .element-specimen__figure span { height:calc(2rem + var(--bar,0)*1rem); border-radius:var(--radius-s) var(--radius-s) 0 0; background:var(--semantic-action,var(--primary)); }
  .element-specimen__figure span:nth-child(1) { height:3rem; opacity:.35; }.element-specimen__figure span:nth-child(2) { height:5rem; opacity:.55; }.element-specimen__figure span:nth-child(3) { height:7rem; opacity:.75; }.element-specimen__figure span:nth-child(4) { height:9rem; }
  .element-specimen__figure figcaption { padding:var(--space-s) var(--space-xl); font-size:var(--text-s); }
  .element-specimen__disclosure { display:grid; gap:var(--space-s); padding:var(--space-xl); }
  .element-specimen__disclosure details { border:1px solid var(--semantic-border,#cbd5e1); border-radius:var(--radius-s); padding:var(--space-s); }
  .element-specimen__disclosure summary { font-weight:800; cursor:pointer; }
  .element-specimen__disclosure details p { margin:var(--space-xs) 0 0; }
  .element-specimen__disclosure > .btn { justify-self:start; }
  .element-specimen dialog { width:min(28rem,calc(100vw - 2rem)); border:0; border-radius:var(--radius-m); padding:var(--space-xl); box-shadow:0 2rem 5rem rgb(15 23 42/.3); }
  .element-specimen dialog::backdrop { background:rgb(15 23 42/.45); }
  .element-specimen dialog h3,.element-specimen dialog p { margin-top:0; }
  .element-specimen dialog form { display:flex; justify-content:flex-end; gap:var(--space-xs); }
  @media(max-width:620px){.element-specimen__form{grid-template-columns:1fr}.element-specimen__form p{grid-column:auto}.element-specimen__type,.element-specimen__actions,.element-specimen__form,.element-specimen__table-wrap,.element-specimen__disclosure{padding:var(--space-m)}}
</style>
