---
// PROTOTYPE — Variant B: layered editorial homepage, driven by live framework tokens.
import { ArrowRight, HeartHandshake, Home, MapPin, Quote, ShieldCheck, Sparkles } from "@lucide/astro";

const services = [
  [HeartHandshake, "Lorem ipsum", "Lorem ipsum dolor sit amet, consectetur adipiscing elit."],
  [Sparkles, "Dolor sit amet", "Sed do eiusmod tempor incididunt ut labore et dolore."],
  [Home, "Consectetur", "Ut enim ad minim veniam, quis nostrud exercitation."],
  [ShieldCheck, "Adipiscing elit", "Duis aute irure dolor in reprehenderit in voluptate."],
];
const stories = [
  ["https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1100&q=85", "Lorem ipsum dolor sit amet"],
  ["https://images.unsplash.com/photo-1529156069898-49953e39b3ac?auto=format&fit=crop&w=1100&q=85", "Viverra tellus in hac"],
  ["https://images.unsplash.com/photo-1511632765486-a01980e01a18?auto=format&fit=crop&w=1100&q=85", "Magna etiam tempor"],
];
---

<main class="site-b container" data-prototype-view="B" hidden>
  <nav class="site-b__nav" aria-label="Lorem ipsum navigation">
    <a class="site-b__brand" href="#b-top"><HeartHandshake size={24}/><span>Lorem Ipsum</span></a>
    <div><a href="#b-services">Lorem ipsum</a><a href="#b-story">Dolor sit</a><a href="#b-news">Amet consectetur</a></div>
    <a class="site-b__nav-cta btn small" href="#b-cta">Lorem ipsum</a>
  </nav>

  <section class="site-b__hero section" id="b-top">
    <div class="site-b__hero-copy">
      <p class="site-b__eyebrow badge">Amet consectetur</p>
      <h1>Lorem ipsum dolor sit amet.</h1>
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc non blandit massa enim nec dui nunc.</p>
      <div class="site-b__actions"><a class="btn" href="#b-services">Lorem ipsum <ArrowRight size={16} /></a><a class="btn ghost" href="#b-story">Dolor sit</a></div>
    </div>
    <figure class="site-b__hero-media">
      <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1800&q=85" alt="People having a conversation around a table" />
    </figure>
  </section>

  <section class="site-b__proof section" aria-label="Lorem ipsum statistics">
    <article><HeartHandshake size={22}/><strong>2.400+</strong><span>Lorem ipsum</span></article>
    <article><Sparkles size={22}/><strong>9,1</strong><span>Dolor sit amet</span></article>
    <article><MapPin size={22}/><strong>25+</strong><span>Amet consectetur</span></article>
    <article><ShieldCheck size={22}/><strong>15 jaar</strong><span>Adipiscing elit</span></article>
  </section>

  <section class="site-b__services section" id="b-services">
    <header><p class="site-b__eyebrow">Amet consectetur</p><h2>Viverra tellus</h2><span>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</span></header>
    <div>{services.map(([Icon,title,copy], index) => <article class:list={["card", "card-icon", index === 1 && "secondary"]}><i class="card-icon__icon"><Icon size={50}/></i><h3 class="card-icon__title">{title}</h3><p class="card-icon__lede">{copy}</p><a class="clickable-parent" href="#b-story" aria-label={`Meer informatie over ${title}`}></a></article>)}</div>
  </section>

  <section class="site-b__story section" id="b-story">
    <figure><img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=1400&q=85" alt="Person sitting beside a sunlit window" /></figure>
    <div><p class="site-b__eyebrow badge">Magna etiam</p><h2>Nulla facilisi morbi tempus</h2><p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque vitae sapien vitae sem faucibus fermentum. Integer ut augue eget sapien vestibulum ullamcorper.</p><a class="btn" href="#b-news">Lorem ipsum <ArrowRight size={16}/></a></div>
  </section>

  <figure class="site-b__quote">
    <Quote class="site-b__quote-mark" size={42}/>
    <blockquote><p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer ut augue eget sapien vestibulum.</p></blockquote>
    <figcaption><img src="https://images.unsplash.com/photo-1544126592-807ade215a0b?auto=format&fit=crop&w=320&q=85" alt="Parent holding a baby" /><span><strong>Lorem ipsum dolor</strong><small>Amet consectetur</small></span></figcaption>
  </figure>

  <section class="site-b__news section" id="b-news">
    <header><div><p class="site-b__eyebrow">Viverra tellus</p><h2>Amet consectetur</h2></div><a class="btn link small" href="#b-cta">Lorem ipsum <ArrowRight size={16}/></a></header>
    <div>{stories.map(([image,title]) => <article class="card card-blog"><img class="card-blog__media" src={image} alt="Editorial lifestyle"/><div class="card-blog__content"><small class="card-blog__meta">12 mei 2026</small><h3 class="card-blog__title">{title}</h3><p class="card-blog__lede">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p><span class="btn no-bg small card-link-label" aria-hidden="true">Lorem ipsum <ArrowRight size={15}/></span></div><a class="clickable-parent" href="#b-cta" aria-label={`Lees meer over ${title}`}></a></article>)}</div>
  </section>

  <section class="site-b__feature-wide section">
    <div><p class="site-b__eyebrow badge">Viverra tellus</p><h2>Aliquam etiam erat velit</h2><p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent libero sed cursus ante dapibus diam.</p><a class="btn ghost" href="#b-cta">Dolor sit amet <ArrowRight size={16}/></a></div>
    <figure><img src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?auto=format&fit=crop&w=1800&q=85" alt="Friends spending time together outdoors" /></figure>
  </section>

  <section class="site-b__split section">
    <figure><img src="https://images.unsplash.com/photo-1474552226712-ac0f0961a954?auto=format&fit=crop&w=1400&q=85" alt="Two people cycling together at sunset" /></figure>
    <div><p class="site-b__eyebrow badge">Samen verder</p><h2>Voor cliënten en hun naasten</h2><p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc feugiat mi a tellus consequat imperdiet.</p><div class="site-b__actions"><a class="btn" href="#b-cta">Lorem ipsum <ArrowRight size={16}/></a></div></div>
  </section>

  <section class="site-b__testimonials section"><header><p class="site-b__eyebrow badge secondary">Nulla facilisi</p><h2>Lorem ipsum dolor</h2></header><div>{[1,2,3].map((item)=><blockquote class="card testimonial-card"><p>“Lorem ipsum dolor sit amet, consectetur adipiscing elit. Etiam dignissim, lacus vel rhoncus elementum.”</p><cite>Lorem ipsum {item}</cite></blockquote>)}</div></section>

  <section class="site-b__cta card primary" id="b-cta"><i><HeartHandshake size={30}/></i><div><p class="site-b__eyebrow badge">Amet consectetur</p><h2>Lorem ipsum dolor sit amet.</h2></div><p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p><a class="btn secondary" href="#b-top">Lorem ipsum <ArrowRight size={16}/></a></section>

  <footer class="site-b__footer">
    <div class="site-b__footer-contact">
      <a class="site-b__brand" href="#b-top"><HeartHandshake size={28}/><span>Lorem Ipsum</span></a>
      <address>
        <span>Nieuwe Gracht 24</span>
        <span>3512 LS Utrecht</span>
        <a href="mailto:hallo@loremipsum.nl">hallo@loremipsum.nl</a>
        <a href="tel:+31301234567">+31 (0)30 123 45 67</a>
      </address>
    </div>
    {["Lorem ipsum","Dolor sit","Amet consectetur","Nulla facilisi"].map((title)=><div><strong>{title}</strong><a href="#b-services">Lorem ipsum</a><a href="#b-story">Dolor sit amet</a><a href="#b-news">Consectetur</a></div>)}
  </footer>
</main>

<style>
  .site-b{--b-ink:var(--semantic-text,#253f42);--b-surface:var(--semantic-surface,#fbf7f0);--b-action:var(--semantic-action,var(--color-primary));--b-border:var(--semantic-border,#d9d5cc);width:min(100%,var(--fp-viewport,90rem));margin-inline:auto;overflow:hidden;background:var(--b-surface);color:var(--b-ink);font:var(--text-s)/1.55 var(--fp-font),system-ui,sans-serif}
  .site-b *{box-sizing:border-box}.site-b h1,.site-b h2,.site-b h3,.site-b p,.site-b figure,.site-b blockquote{margin:0}.site-b p{font-size:var(--text-m)}.site-b img{display:block;width:100%;height:100%;object-fit:cover}.site-b a{color:inherit;text-decoration:none}.site-b a:focus-visible{outline:4px solid var(--semantic-focus,var(--b-action));outline-offset:4px}
  .site-b{--primary:var(--color-primary);--primary-lightest:var(--color-primary-lightest);--primary-lighter:var(--color-primary-lighter);--primary-light:var(--color-primary-light);--primary-dark:var(--color-primary-dark);--primary-darker:var(--color-primary-darker);--primary-darkest:var(--color-primary-darkest);--secondary:var(--color-primary-lighter);--dark-10:color-mix(in oklch,var(--primary-darkest) 10%,transparent);--text-body:var(--semantic-text);--bg-surface:var(--semantic-surface);--btn-space:var(--space-3xs) var(--space-s);--card-space:var(--space-s);--shadow-m:0 var(--space-4xs) var(--space-s) color-mix(in oklch,var(--primary-darkest) 12%,transparent);--max-screen-width:var(--section-max-width,90rem);--min-screen-width:min(100%,var(--section-min-width,20rem))}
  .site-b .btn{display:flex;align-items:center;justify-content:center;gap:var(--space-3xs);padding:var(--btn-space);background:var(--btn-main-color);color:white;font-size:var(--text-m);font-weight:600;line-height:1.1;border-radius:var(--radius-m);border:2px solid var(--btn-main-color);transition:all .25s ease-in-out;outline:0;cursor:pointer;--btn-color:var(--primary);--btn-main-color:var(--btn-color)}
  .site-b .btn:hover{--btn-main-color:color-mix(in oklch,var(--btn-color),black 20%);transform:translateY(-.1rem)}
  .site-b .btn.small{padding:var(--space-4xs) var(--space-xs);font-size:var(--text-s)}.site-b .btn.large{font-size:var(--text-l)}
  .site-b .btn.ghost{--btn-color:var(--primary);background:transparent;color:var(--btn-main-color)}.site-b .btn.secondary{--btn-color:var(--secondary);color:black}
  .site-b .btn.ghost:hover{background:color-mix(in oklch,var(--btn-main-color) 10%,transparent);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
  .site-b .btn:focus-visible{outline:4px solid var(--primary-lightest);outline-offset:2px}.site-b .btn.no-bg,.site-b .btn.link{justify-content:flex-start;padding:0;background:transparent;box-shadow:none;border-color:transparent;color:var(--btn-color)}.site-b .btn.no-bg:hover,.site-b .btn.link:hover{background:transparent;color:color-mix(in oklch,var(--btn-color),black 20%)}
  .site-b .badge{display:flex;align-items:center;justify-content:center;gap:var(--space-4xs);width:max-content;padding:var(--space-2xs) var(--space-s);background:var(--dark-10);color:var(--primary);font-size:var(--text-s);font-weight:500;line-height:1;border-radius:var(--radius-full);border:0;outline:0}.site-b .badge.secondary{color:var(--secondary)}
  .site-b .card{display:grid;gap:var(--space-xs);padding:var(--card-space);font-size:var(--text-m);color:var(--text-body);background:var(--bg-surface);line-height:1.3;border-radius:var(--radius-m);box-shadow:var(--shadow-m)}.site-b .card.secondary{background:var(--secondary);color:#000}.site-b .card.primary{background:var(--primary);color:#fff;--shadow-primary:var(--primary)}
  .site-b .text-xs{font-size:var(--text-xs);line-height:var(--text-xs)}.site-b .text-s{font-size:var(--text-s);line-height:var(--text-s)}.site-b .text-m{font-size:var(--text-m);line-height:var(--text-m)}.site-b .text-l{font-size:var(--text-l);line-height:var(--text-l)}.site-b .text-xl{font-size:var(--text-xl);line-height:var(--text-xl)}.site-b .text-2xl{font-size:var(--text-2xl);line-height:var(--text-2xl)}.site-b .text-3xl{font-size:var(--text-3xl);line-height:var(--text-3xl)}.site-b .text-4xl{font-size:var(--text-4xl);line-height:var(--text-4xl)}
  .site-b .section{width:100%;display:grid}.site-b .site-b__split.section{width:auto}.site-b.container{max-width:var(--max-screen-width);width:100%;min-width:var(--min-screen-width);display:grid}
  .site-b__nav{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:var(--space-m);min-height:4.5rem;padding:var(--space-s) var(--space-xl);background:var(--b-surface)}.site-b__nav>div{display:flex;gap:var(--space-l)}.site-b__brand{font:700 var(--text-l)/1.1 Georgia,serif}.site-b__nav-cta{justify-self:end;border-radius:var(--radius-full);padding:var(--space-xs) var(--space-s);background:var(--b-action);color:white!important;font-weight:700}
  .site-b__hero{position:relative;display:grid;grid-template-columns:.82fr 1.18fr;min-height:42rem}.site-b__hero-copy{z-index:2;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;padding:var(--space-3xl) var(--space-xl)}.site-b__hero-copy h1{max-width:10ch;font:500 var(--text-4xl)/.98 Georgia,serif;letter-spacing:-.045em}.site-b__hero-copy h1 em{color:var(--b-action);font-style:normal}.site-b__hero-copy>p:not(.site-b__eyebrow){max-width:36rem;margin-top:var(--space-m)}.site-b__eyebrow{color:var(--b-action);font-size:var(--text-xs);font-weight:800;letter-spacing:.1em;text-transform:uppercase}.site-b__hero-media{position:relative;min-height:38rem;overflow:hidden;border-radius:45% 0 0 42%}.site-b__hero-media:after{position:absolute;inset:10% -8% -12% 18%;border:clamp(.5rem,1.2vw,1.1rem) solid color-mix(in oklch,var(--b-action) 68%,transparent);border-radius:48%;content:"";pointer-events:none}.site-b__actions{display:flex;flex-wrap:wrap;gap:var(--space-s);margin-top:var(--space-l)}.site-b__actions a,.site-b__story a,.site-b__cta>a{display:flex;align-items:center;justify-content:center;gap:var(--space-3xs);min-height:2.75rem;border:2px solid var(--b-action);border-radius:var(--radius-full);padding:var(--space-xs) var(--space-s);font-weight:750}.site-b__actions a:first-child,.site-b__story a,.site-b__cta>a{background:var(--b-action);color:white}
  .site-b__proof{position:relative;z-index:3;display:grid;grid-template-columns:repeat(4,1fr);width:min(72rem,calc(100% - var(--space-xl)*2));margin:calc(var(--space-xl)*-1) auto var(--space-xl);border-radius:var(--radius-l);padding:var(--space-m);background:var(--b-surface);box-shadow:0 var(--space-xs) var(--space-xl) color-mix(in oklch,var(--b-ink) 12%,transparent)}.site-b__proof article{display:grid;grid-template-columns:auto auto;justify-content:center;gap:0 var(--space-xs);border-right:1px solid var(--b-border);padding:var(--space-xs)}.site-b__proof article:last-child{border:0}.site-b__proof svg{grid-row:1/3;align-self:center;color:var(--b-action)}.site-b__proof span{font-size:var(--text-xs)}
  .site-b__services{padding:var(--space-2xl) var(--space-xl)}.site-b__services header{max-width:42rem}.site-b h2{font:500 var(--text-3xl)/1.02 Georgia,serif;letter-spacing:-.035em}.site-b__services header>span{display:block;margin-top:var(--space-s)}.site-b__services>div{display:grid;grid-template-columns:repeat(auto-fit,minmax(11.25rem,1fr));gap:var(--space-xl);margin-top:var(--space-xl)}.site-b__services h3,.site-b__news h3{font:600 var(--text-m)/1.2 Georgia,serif}
  .site-b__story,.site-b__split{display:grid;grid-template-columns:1.05fr .95fr;align-items:center;padding:var(--space-2xl) var(--space-xl)}.site-b__story figure{height:34rem;margin-left:calc(var(--space-xl)*-1);overflow:hidden;border-radius:0 var(--radius-xl) var(--radius-xl) 0}.site-b__story>div,.site-b__split>div{display:grid;justify-items:start;gap:var(--space-m);padding:var(--space-xl)}.site-b__quote{position:relative;z-index:2;display:grid;grid-template-columns:auto 1fr;align-items:center;min-height:17rem;margin-top:calc(var(--space-xl)*-1);padding:var(--space-xl) 46% var(--space-xl) var(--space-xl);overflow:hidden;border-radius:0 0 20% 0;background:color-mix(in oklch,var(--b-action) 12%,var(--b-surface))}.site-b__quote>span{font:700 var(--text-4xl)/.7 Georgia,serif;color:var(--b-action)}.site-b__quote>p{font:500 var(--text-xl)/1.2 Georgia,serif}.site-b__quote cite{grid-column:2;font-size:var(--text-xs)}.site-b__quote img{position:absolute;inset:0 0 0 auto;width:42%;border-radius:55% 0 0 45%}
  .site-b__news{padding:var(--space-2xl) var(--space-xl)}.site-b__news>header{display:flex;align-items:end;justify-content:space-between;gap:var(--space-m)}.site-b__news>header>a{display:flex;gap:var(--space-xs);font-weight:700}.site-b__news>div{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-s);margin-top:var(--space-l)}.site-b__news article{display:grid;gap:var(--space-xs);border-left:1px solid var(--b-border);padding-left:var(--space-s)}.site-b__news article img{height:17rem;border-radius:var(--radius-l)}.site-b__news article:nth-child(2){transform:translateY(var(--space-l))}.site-b__news small,.site-b__news article>a{color:var(--b-action);font-size:var(--text-xs);font-weight:700}
  .site-b__split{grid-template-columns:1.05fr .95fr;margin:var(--space-2xl) var(--space-xl);padding:0;overflow:hidden;border:1px solid var(--b-border);border-radius:var(--radius-xl);background:color-mix(in oklch,var(--b-action) 6%,var(--b-surface))}.site-b__split figure{grid-column:1;height:31rem;overflow:hidden}.site-b__split>div{grid-column:2;grid-row:1}.site-b__testimonials{position:relative;padding:var(--space-2xl) var(--space-xl) calc(var(--space-3xl) + var(--space-l));background:color-mix(in oklch,var(--b-ink) 92%,var(--b-action));color:var(--b-surface)}.site-b__testimonials .site-b__eyebrow{color:color-mix(in oklch,var(--b-action) 60%,white)}.site-b__testimonials>div{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-l);margin-top:var(--space-xl)}.site-b__testimonials blockquote{border-left:1px solid color-mix(in oklch,var(--b-surface) 35%,transparent);padding-left:var(--space-m)}.site-b__testimonials cite{display:block;margin-top:var(--space-s);font-size:var(--text-xs)}
  .site-b__cta{position:relative;z-index:4;display:grid;grid-template-columns:auto 1.2fr 1fr auto;align-items:center;gap:var(--space-l);width:calc(100% - var(--space-xl)*2);margin:calc(var(--space-xl)*-1) auto 0;border-radius:var(--radius-full);padding:var(--space-l);background:var(--b-action);color:white}.site-b__cta>i{display:grid;place-items:center;width:4rem;height:4rem;border:1px solid color-mix(in oklch,white 50%,transparent);border-radius:var(--radius-full)}.site-b__cta .site-b__eyebrow{color:white;opacity:.8}.site-b__cta h2{font-size:var(--text-xl)}.site-b__cta>a{border-color:white;background:white;color:var(--b-action)}
  .site-b__footer{display:grid;grid-template-columns:1.35fr repeat(4,1fr);gap:var(--space-l);padding:var(--space-2xl) var(--space-xl) var(--space-xl);border-top:1px solid var(--primary-dark);background:var(--primary-darkest);color:var(--primary-lightest)}.site-b__footer>div{display:grid;align-content:start;gap:var(--space-xs)}.site-b__footer>div a{color:color-mix(in oklch,var(--primary-lightest) 78%,var(--primary-light));font-size:var(--text-xs)}.site-b__footer>div strong{color:var(--primary-lightest)}.site-b__footer .site-b__footer-contact{gap:var(--space-s)}.site-b__footer .site-b__brand{color:var(--primary-lightest)}.site-b__footer .site-b__brand svg{color:var(--primary-light)}.site-b__footer-contact address{display:grid;gap:var(--space-3xs);color:color-mix(in oklch,var(--primary-lightest) 78%,transparent);font-size:var(--text-xs);font-style:normal;line-height:1.45}.site-b__footer-contact address a{width:max-content;color:var(--primary-light);font-weight:650}
  .site-b__brand{display:inline-flex;align-items:center;gap:var(--space-3xs)}.site-b__brand svg{color:var(--primary)}
  .site-b .site-b__proof{width:min(64rem,calc(100% - var(--space-3xl)*2));border:1px solid color-mix(in oklch,var(--primary) 12%,var(--b-border));border-radius:var(--radius-xl);box-shadow:0 var(--space-s) var(--space-2xl) color-mix(in oklch,var(--primary-darkest) 14%,transparent)}
  .site-b {
    .clickable-parent{position:absolute;inset:0;z-index:2;display:block;border-radius:inherit;outline:0;cursor:pointer}
    .card:has(.clickable-parent){position:relative;transition:transform .25s ease,box-shadow .25s ease}
    .card:has(.clickable-parent):hover{transform:translate3d(0,-.3rem,0)}
    .card:has(.clickable-parent:focus-visible){outline:4px solid var(--primary-light);outline-offset:4px}
