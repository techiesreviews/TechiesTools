---
import { ChevronDown, ExternalLink } from "@lucide/astro";
import { getCollection } from "astro:content";
import FrameworkCombobox, { type ComboboxGroup } from "./FrameworkCombobox.prototype.astro";
import TreatmentCssEditor from "./TreatmentCssEditor.astro";
import { canonicalFrameworkRoute } from "../../framework/routes";
import { treatmentModules } from "../../framework/treatments/index";
import { buildElementCatalog } from "../../framework/catalog/index";

const elementReferencePath = canonicalFrameworkRoute("elements")!.path;

const guidance = (await getCollection("elements")).map((entry) => ({ id: entry.id, ...entry.data }));
const catalogResult = buildElementCatalog({
  guidance,
  treatments: treatmentModules,
  tokens: new Map([
    ...["semantic.primary", "semantic.action", "semantic.surface", "semantic.text", "semantic.border", "semantic.focus"].map((id) => [id, "color"] as const),
    ...["spacing.3xs", "spacing.s", "typography.m", "radius.m"].map((id) => [id, "dimension"] as const),
  ]),
});
if (!catalogResult.success) throw new Error(catalogResult.diagnostics.map((item) => item.message).join("\n"));
const catalog = catalogResult.data;
const elementGroups:ComboboxGroup[] = [...new Set(catalog.elements.map((entry) => entry.group))].map((group) => ({
  label: group,
  options: catalog.group(group).map((entry) => ({ value: entry.id, label: entry.title, meta: `${entry.group} › <${entry.id}>`, preview: entry.id, previewType: "tag" as const })),
}));
const ruleLabels:Record<string,string>={
  base:"Base",
  hover:"Hover",
  "focus-visible":"Focus visible",
  active:"Active",
  quiet:"Quiet",
  disabled:"Disabled",
  secondary:"Secondary",
  "link-in-navigation/current":"Current navigation",
};
const treatmentElements = catalog.elements.filter((entry) => entry.definition).map((entry) => ({
  id: entry.id,
  title: entry.title,
  rules: entry.rules.map(({ path, rule }) => {
    const key = path.slice(entry.id.length + 1);
    return { key, label: ruleLabels[key] ?? rule.id, selector: rule.selector, lineCount: Object.values(rule.declarations).filter((declaration) => declaration.starter.kind !== "omit").length };
  }),
}));
const treatmentElementIds = treatmentElements.map((entry) => entry.id);
const elementData = Object.fromEntries(catalog.elements.map((entry) => [entry.id, { title: entry.title, intent: entry.group }]));
---
<section class="framework-accordion elements-editor" data-framework-accordion="elements" data-elements-editor data-element-reference-path={elementReferencePath} data-element-data={JSON.stringify(elementData)}>
  <button class="framework-accordion__trigger" type="button" aria-expanded="false" data-accordion-trigger><span>Elements</span><span class="framework-accordion__summary">92 elements</span><ChevronDown size={13}/></button>
  <div class="framework-accordion__content" hidden data-accordion-content>
    <FrameworkCombobox id="element-picker" label="Element" placeholder="Find an intent or element" groups={elementGroups} hideLabel />
    <a class="elements-editor__open" href={`${elementReferencePath}#h1`} hidden data-element-link><span data-element-link-label>Open element</span><ExternalLink size={11}/></a>
    <article class="elements-editor__settings" hidden data-element-settings>
      <section class="elements-editor__treatment" hidden data-element-treatment data-treatment-element-ids={JSON.stringify(treatmentElementIds)}>
        <header><strong>Element treatment</strong><button type="button" data-element-reset>Reset element</button></header>
        {treatmentElements.map((entry) => (
          <fieldset hidden data-generated-treatment={entry.id}>
            <legend class="sr-only">{entry.title}</legend>
            <label class="elements-editor__state-picker">
              <span>State</span>
              <select data-treatment-state-select data-element-id={entry.id}>
                {entry.rules.map((rule) => <option value={rule.key}>{rule.label}</option>)}
              </select>
            </label>
            {entry.rules.map((rule, ruleIndex) => (
              <section data-treatment-rule={rule.key} hidden={ruleIndex > 0 ? true : undefined}>
                <TreatmentCssEditor elementId={entry.id} ruleId={rule.key} selector={rule.selector} label={rule.label} lineCount={rule.lineCount} />
              </section>
            ))}
          </fieldset>
        ))}
      </section>
      <p data-native-element-note>Native Fallback. No visual Framework treatment is authored.</p>
    </article>
  </div>
</section>
<script>
  const editor=document.querySelector<HTMLElement>("[data-elements-editor]");
  const elementReferencePath=editor?.dataset.elementReferencePath ?? "";
  const settings=editor?.querySelector<HTMLElement>("[data-element-settings]");
  const elementData:Record<string,{title:string;intent:string}>=JSON.parse(editor?.dataset.elementData ?? "{}");
  type ElementUiState = { selectedElement:string|null; treatmentRule:string|null };
  const treatmentPanel=editor?.querySelector<HTMLElement>("[data-element-treatment]");
  const treatmentIds:string[]=JSON.parse(treatmentPanel?.dataset.treatmentElementIds ?? "[]");
  const currentTreatment=()=>treatmentPanel?.dataset.treatmentElement ?? null;
  const setTreatmentRule=(elementId:string,state:string)=>{const stateSelect=editor?.querySelector<HTMLSelectElement>(`[data-treatment-state-select][data-element-id="${CSS.escape(elementId)}"]`);if(!stateSelect)return;stateSelect.value=state;stateSelect.closest("fieldset")?.querySelectorAll<HTMLElement>("[data-treatment-rule]").forEach((section)=>{section.hidden=section.dataset.treatmentRule!==state;});};
  const publishElementUiState=()=>window.dispatchEvent(new CustomEvent<ElementUiState>("framework-elements:state-change",{detail:{selectedElement:currentTreatment() ?? editor?.dataset.selectedElement ?? null,treatmentRule:currentTreatment() ? editor?.querySelector<HTMLSelectElement>(`[data-treatment-state-select][data-element-id="${CSS.escape(currentTreatment()!)}"]`)?.value ?? null : null}}));
  const clearElementSelection=()=>{editor?.removeAttribute("data-selected-element");if(settings)settings.hidden=true;if(treatmentPanel){treatmentPanel.hidden=true;treatmentPanel.removeAttribute("data-treatment-element");}treatmentPanel?.querySelectorAll<HTMLElement>("[data-generated-treatment]").forEach((set)=>set.hidden=true);const nativeNote=editor?.querySelector<HTMLElement>("[data-native-element-note]");if(nativeNote)nativeNote.hidden=false;const link=editor?.querySelector<HTMLAnchorElement>("[data-element-link]");if(link)link.hidden=true;const picker=editor?.querySelector<HTMLElement>('[data-combobox-id="element-picker"]');const input=picker?.querySelector<HTMLInputElement>("[data-combobox-input]");const meta=picker?.querySelector<HTMLElement>("[data-combobox-value]");const preview=picker?.querySelector<HTMLElement>("[data-combobox-selected-preview]");if(input)input.value="";if(meta)meta.textContent="";if(preview)preview.hidden=true;picker?.querySelector<HTMLElement>("[data-combobox-search-icon]")?.removeAttribute("hidden");picker?.querySelectorAll<HTMLElement>("[data-combobox-option]").forEach((option)=>option.setAttribute("aria-selected","false"));};
  const selectElement=(value:string,label?:string,{publish=true,state}:{publish?:boolean;state?:string|null}={})=>{const item=elementData[value];if(!item)return;if(settings)settings.hidden=false;const hasTreatment=treatmentIds.includes(value);editor?.setAttribute("data-selected-element",value);if(treatmentPanel)treatmentPanel.hidden=!hasTreatment;treatmentPanel?.setAttribute("data-treatment-element",value);treatmentPanel?.querySelectorAll<HTMLElement>("[data-generated-treatment]").forEach((set)=>set.hidden=set.dataset.generatedTreatment!==value);const nativeNote=editor?.querySelector<HTMLElement>("[data-native-element-note]");if(nativeNote)nativeNote.hidden=hasTreatment;const link=editor?.querySelector<HTMLAnchorElement>("[data-element-link]");const linkLabel=link?.querySelector<HTMLElement>("[data-element-link-label]");const picker=editor?.querySelector<HTMLElement>('[data-combobox-id="element-picker"]');const input=picker?.querySelector<HTMLInputElement>("[data-combobox-input]");const meta=picker?.querySelector<HTMLElement>("[data-combobox-value]");picker?.querySelectorAll<HTMLElement>("[data-combobox-option]").forEach((option)=>option.setAttribute("aria-selected",String(option.dataset.value===value)));if(input)input.value=label??item.title;if(meta)meta.textContent=`${item.intent} › <${value}>`;if(link){link.hidden=false;link.href=`${elementReferencePath}#${value}`;}if(linkLabel)linkLabel.textContent=`Open <${value}>`;if(hasTreatment)setTreatmentRule(value,state ?? "base");if(hasTreatment)window.dispatchEvent(new CustomEvent("framework-elements:request-state"));if(publish)publishElementUiState();};
  editor?.addEventListener("framework-combobox:select",(event)=>{const detail=(event as CustomEvent).detail;if(detail.id!=="element-picker")return;selectElement(detail.value,detail.label);});
  editor?.querySelectorAll<HTMLSelectElement>("[data-treatment-state-select]").forEach((stateSelect)=>stateSelect.addEventListener("change",()=>{setTreatmentRule(stateSelect.dataset.elementId ?? "",stateSelect.value);window.dispatchEvent(new CustomEvent("framework-elements:request-state",{detail:{reason:"state"}}));publishElementUiState();}));
  editor?.querySelector("[data-element-reset]")?.addEventListener("click",()=>{const elementId=currentTreatment();if(elementId)window.dispatchEvent(new CustomEvent("framework-elements:reset-element",{detail:{elementId}}));});
  window.addEventListener("framework-elements:apply-ui-state",(event)=>{const state=(event as CustomEvent<ElementUiState>).detail;if(!state?.selectedElement){clearElementSelection();return;}selectElement(state.selectedElement,undefined,{publish:false,state:state.treatmentRule});});
</script>
<style>
  .elements-editor__treatment { display:grid; gap:8px; min-width:0; }
  .elements-editor__treatment > header { display:flex; align-items:center; justify-content:space-between; gap:8px; min-height:24px; padding-inline:2px; }
  .elements-editor__treatment > header > strong { color:var(--ink); font-size:10px; font-weight:800; letter-spacing:.01em; }
  .elements-editor__treatment > header > button { border:0; padding:3px 0; background:transparent; color:var(--muted); font-size:9px; font-weight:700; cursor:pointer; }
  .elements-editor__treatment > header > button:hover,.elements-editor__treatment > header > button:focus-visible { color:var(--accent); }
  .elements-editor__treatment > header > button:focus-visible { outline:2px solid var(--accent); outline-offset:2px; }
  .elements-editor__treatment fieldset { display:grid; gap:18px; min-inline-size:0; margin:0; overflow:visible; border:0; padding:0; background:transparent; }
  .elements-editor__treatment fieldset > legend { float:none; width:auto; border:0; padding:0; background:transparent; color:var(--accent); font-size:10px; font-weight:850; }
  .elements-editor__treatment fieldset > legend.sr-only { position:absolute; width:1px; height:1px; overflow:hidden; clip-path:inset(50%); white-space:nowrap; }
  .elements-editor__treatment [data-treatment-rule] { clear:both; display:grid; grid-template-columns:minmax(0,1fr); gap:8px; border:0; padding:0; }
  .elements-editor__state-picker { display:grid; gap:4px; color:var(--muted); font-size:9px; font-weight:700; }
  .elements-editor__state-picker select { width:100%; min-width:0; height:32px; border:1px solid var(--line); border-radius:6px; padding:0 25px 0 8px; background:#fff; color:var(--ink); font-size:10px; font-weight:700; }
  .elements-editor__state-picker select:focus-visible { border-color:var(--accent); outline:2px solid color-mix(in srgb,var(--accent) 22%,transparent); outline-offset:1px; }
</style>
<style>.elements-editor__open{display:flex;align-items:center;justify-content:flex-end;gap:4px;margin-top:-1px;color:var(--accent);font-size:9px;font-weight:800}.elements-editor__settings{display:grid;gap:16px;margin-top:0;padding:4px 2px 2px}</style>
