---
import { ChevronDown, Clipboard, Copy, Plus, Trash2, X } from "@lucide/astro";

const initialColors = [
  { name: "Primary color", value: "#2563EB" },
];
---

<aside class="framework-sidebar" aria-label="Framework sidebar" data-framework-sidebar>
  <header class="framework-sidebar__header">
    <p class="framework-sidebar__eyebrow">Tools /</p>
    <h2 class="framework-sidebar__title">Framework</h2>
  </header>

  <section class="framework-sidebar__group" aria-labelledby="framework-colors">
    <button class="framework-sidebar__accordion-button" type="button" aria-expanded="true" data-accordion-trigger>
      <span class="framework-sidebar__accordion-label" id="framework-colors">Colors</span>
      <span class="framework-sidebar__summary">
        <span class="framework-sidebar__swatches" aria-label="Added colors" data-color-swatches></span>
      </span>
      <ChevronDown class="framework-sidebar__chevron" size={13} stroke-width={2} />
    </button>

    <div class="framework-sidebar__accordion-content" data-accordion-content>
      <div class="framework-sidebar__color-list" data-color-list>
        {
          initialColors.map((color) => (
            <div class="framework-sidebar__color-row" data-color-row>
              <label class="framework-sidebar__name-field">
                <span class="framework-sidebar__visually-hidden">Color name</span>
                <input class="framework-sidebar__name-input" type="text" value={color.name} data-color-name />
              </label>
              <button class="framework-sidebar__remove-button" type="button" aria-label={`Remove ${color.name}`} data-remove-color>
                <Trash2 size={12} stroke-width={2} />
              </button>
              <div class="framework-sidebar__color-input">
                <input class="framework-sidebar__picker" type="color" value={color.value} aria-label={`${color.name} picker`} data-color-picker />
                <input class="framework-sidebar__hex-input" type="text" value={color.value} data-color-hex />
              </div>
              <div class="framework-sidebar__color-scale" aria-label={`${color.name} scale`} data-color-scale>
                {Array.from({ length: 6 }).map(() => <span></span>)}
              </div>
            </div>
          ))
        }
      </div>

      <button class="framework-sidebar__add-button" type="button" data-add-color>
        <Plus size={13} stroke-width={2} />
        <span>Add color</span>
      </button>
    </div>
  </section>

  <section class="framework-sidebar__group" aria-label="Framework settings">
    <button class="framework-sidebar__accordion-button" type="button" aria-expanded="false" data-accordion-trigger>
      <span class="framework-sidebar__accordion-label">Type</span>
      <span class="framework-sidebar__preview">Aa Aa Aa +1</span>
      <ChevronDown class="framework-sidebar__chevron" size={13} stroke-width={2} />
    </button>
    <div class="framework-sidebar__accordion-content" hidden data-accordion-content>
      <p class="framework-sidebar__hint">Type variables define heading/body fonts and the scale bounds for generated CSS.</p>
    </div>

    <button class="framework-sidebar__accordion-button" type="button" aria-expanded="false" data-accordion-trigger>
      <span class="framework-sidebar__accordion-label">Space</span>
      <span class="framework-sidebar__preview">4 8 12 +3</span>
      <ChevronDown class="framework-sidebar__chevron" size={13} stroke-width={2} />
    </button>
    <div class="framework-sidebar__accordion-content" hidden data-accordion-content>
      <p class="framework-sidebar__hint">Space variables define reusable spacing steps for layouts, gaps, and component rhythm.</p>
    </div>
  </section>

  <div class="framework-sidebar__spacer" aria-hidden="true"></div>

  <div class="framework-sidebar__footer">
    <button class="framework-sidebar__primary-button" type="button" data-open-export>Export</button>
    <button class="framework-sidebar__icon-button" type="button" aria-label="Copy export" data-copy-export>
      <Clipboard size={14} stroke-width={2} />
    </button>
  </div>

  <dialog class="framework-sidebar__modal" data-export-modal>
    <div class="framework-sidebar__modal-card">
      <header class="framework-sidebar__modal-header">
        <div>
          <p class="framework-sidebar__eyebrow">Framework</p>
          <h2 class="framework-sidebar__modal-title">Export variables</h2>
        </div>
        <button class="framework-sidebar__icon-button" type="button" aria-label="Close export" data-close-export>
          <X size={14} stroke-width={2} />
        </button>
      </header>
      <pre class="framework-sidebar__export-code"><code data-export-code></code></pre>
      <div class="framework-sidebar__modal-actions">
        <button class="framework-sidebar__primary-button" type="button" data-copy-export>
          <Copy size={13} stroke-width={2} />
          <span>Copy CSS</span>
        </button>
        <button class="framework-sidebar__secondary-button" type="button" data-download-export>Download</button>
      </div>
    </div>
  </dialog>
</aside>

<script>
  const root = document.querySelector<HTMLElement>("[data-framework-sidebar]");
  const list = root?.querySelector<HTMLElement>("[data-color-list]");
  const swatches = root?.querySelector<HTMLElement>("[data-color-swatches]");
  const exportCode = root?.querySelector<HTMLElement>("[data-export-code]");
  const modal = root?.querySelector<HTMLDialogElement>("[data-export-modal]");
  let colorCount = root?.querySelectorAll("[data-color-row]").length ?? 0;

  const normalizeHex = (value: string) => {
    const cleaned = value.trim().replace(/^#/, "");
    if (/^[0-9a-f]{3}$/i.test(cleaned)) {
      return `#${cleaned.split("").map((char) => `${char}${char}`).join("")}`.toUpperCase();
    }
    if (/^[0-9a-f]{6}$/i.test(cleaned)) {
      return `#${cleaned}`.toUpperCase();
    }
    return "#2563EB";
  };

  const hexToRgb = (hex: string) => {
    const value = normalizeHex(hex).slice(1);
    return {
      r: Number.parseInt(value.slice(0, 2), 16),
      g: Number.parseInt(value.slice(2, 4), 16),
      b: Number.parseInt(value.slice(4, 6), 16),
    };
  };

  const rgbToHsl = ({ r, g, b }: { r: number; g: number; b: number }) => {
    const red = r / 255;
    const green = g / 255;
    const blue = b / 255;
    const max = Math.max(red, green, blue);
    const min = Math.min(red, green, blue);
    const lightness = (max + min) / 2;

    if (max === min) {
      return { h: 0, s: 0, l: lightness * 100 };
    }

    const delta = max - min;
    const saturation = lightness > 0.5 ? delta / (2 - max - min) : delta / (max + min);
    const hue =
      max === red
        ? (green - blue) / delta + (green < blue ? 6 : 0)
        : max === green
          ? (blue - red) / delta + 2
          : (red - green) / delta + 4;

    return { h: hue * 60, s: saturation * 100, l: lightness * 100 };
  };

  const toHsla = (hex: string, alpha = 1) => {
    const { h, s, l } = rgbToHsl(hexToRgb(hex));
    const format = (value: number) => Number(value.toFixed(2)).toString();
    return `hsla(${format(h)}, ${format(s)}%, ${format(l)}%, ${alpha})`;
  };

  const rgbToHex = ({ r, g, b }: { r: number; g: number; b: number }) =>
    `#${[r, g, b].map((channel) => Math.round(channel).toString(16).padStart(2, "0")).join("")}`.toUpperCase();

  const mix = (hex: string, target: string, amount: number) => {
    const from = hexToRgb(hex);
    const to = hexToRgb(target);
    return rgbToHex({
      r: from.r + (to.r - from.r) * amount,
      g: from.g + (to.g - from.g) * amount,
      b: from.b + (to.b - from.b) * amount,
    });
  };

  const getScale = (hex: string) => [
    mix(hex, "#FFFFFF", 0.88),
    mix(hex, "#FFFFFF", 0.64),
    mix(hex, "#FFFFFF", 0.32),
    normalizeHex(hex),
    mix(hex, "#000000", 0.24),
    mix(hex, "#000000", 0.48),
  ];

  const slugify = (name: string) =>
    name
      .trim()
      .toLowerCase()
      .replace(/color$/i, "")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-|-$/g, "") || "color";

  const getRows = () =>
    [...(root?.querySelectorAll<HTMLElement>("[data-color-row]") ?? [])].map((row) => {
      const name = row.querySelector<HTMLInputElement>("[data-color-name]")?.value ?? "Color";
      const value = normalizeHex(row.querySelector<HTMLInputElement>("[data-color-hex]")?.value ?? "#2563EB");
      return { row, name, value, slug: slugify(name) };
    });

  const renderExport = () => {
    const primary = getRows()[0] ?? { value: "#2563EB" };
    const lightSteps = [0.88, 0.72, 0.56, 0.4, 0.24].map((amount) => mix(primary.value, "#FFFFFF", amount));
    const darkSteps = [0.12, 0.24, 0.36, 0.48, 0.6].map((amount) => mix(primary.value, "#000000", amount));

    const css = [
      "html {",
      "    font-size: 62.5%;",
      "}",
      "html.cf-theme-dark {",
      "    color-scheme: dark;",
      "}",
      ":root, :root.cf-theme-dark .theme-inverted, :root.cf-theme-dark .theme-always-light, :root.cf-theme-light .theme-inverted .theme-always-light {",
      "    --min-screen-width: 320px;",
      "    --max-screen-width: 1400px;",
      `    --primary: ${toHsla(primary.value)};`,
      ...lightSteps.map((step, index) => `    --primary-l-${index + 1}: ${toHsla(step)};`),
      ...darkSteps.map((step, index) => `    --primary-d-${index + 1}: ${toHsla(step)};`),
      "}",
      ":root.cf-theme-dark, :root.cf-theme-light .theme-inverted, :root.cf-theme-light .theme-always-dark, :root.cf-theme-dark .theme-inverted .theme-always-dark {",
      `    --primary: ${toHsla(lightSteps[2])};`,
      ...lightSteps.map((step, index) => `    --primary-l-${index + 1}: ${toHsla(darkSteps[index])};`),
      ...darkSteps.map((step, index) => `    --primary-d-${index + 1}: ${toHsla(lightSteps[index])};`),
      "}",
      "/* Components */",
      "/* Color System */",
      "/* Fluid Spacing */",
      "/* Fluid Typography */",
    ].join("\n");

    if (exportCode) {
      exportCode.textContent = css;
    }

    return css;
  };

  const renderSwatches = () => {
    if (!swatches) {
      return;
    }

    const rows = getRows();
    const visible = rows.slice(0, 3);
    const extra = rows.length - visible.length;

    swatches.replaceChildren(
      ...visible.map(({ value }) => {
        const item = document.createElement("span");
        item.className = "framework-sidebar__swatch";
        item.style.setProperty("--swatch", value);
        return item;
      }),
    );

    if (extra > 0) {
      const count = document.createElement("span");
      count.className = "framework-sidebar__count";
      count.textContent = `+${extra}`;
      swatches.append(count);
    }
  };

  const renderScales = () => {
    getRows().forEach(({ row, value, name }) => {
      const scale = getScale(value);
      row.querySelectorAll<HTMLElement>("[data-color-scale] span").forEach((step, index) => {
        step.style.setProperty("--step", scale[index]);
      });
      const picker = row.querySelector<HTMLInputElement>("[data-color-picker]");
      if (picker) {
        picker.setAttribute("aria-label", `${name} picker`);
      }
      const remove = row.querySelector<HTMLButtonElement>("[data-remove-color]");
      if (remove) {
        remove.setAttribute("aria-label", `Remove ${name}`);
        remove.disabled = getRows().length <= 1;
      }
    });
  };

  const sync = () => {
    renderScales();
    renderSwatches();
    renderExport();
  };

  const createColorRow = () => {
    colorCount += 1;
    const row = document.createElement("div");
    row.className = "framework-sidebar__color-row";
    row.dataset.colorRow = "";
    row.innerHTML = `
      <label class="framework-sidebar__name-field">
        <span class="framework-sidebar__visually-hidden">Color name</span>
        <input class="framework-sidebar__name-input" type="text" value="Color ${colorCount}" data-color-name />
      </label>
      <button class="framework-sidebar__remove-button" type="button" aria-label="Remove Color ${colorCount}" data-remove-color>
        <svg class="lucide lucide-trash-2" viewBox="0 0 24 24" aria-hidden="true" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 6h18"></path><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path>
        </svg>
      </button>
      <div class="framework-sidebar__color-input">
        <input class="framework-sidebar__picker" type="color" value="#7C3AED" aria-label="Color ${colorCount} picker" data-color-picker />
        <input class="framework-sidebar__hex-input" type="text" value="#7C3AED" data-color-hex />
      </div>
      <div class="framework-sidebar__color-scale" aria-label="Color ${colorCount} scale" data-color-scale>
        <span></span><span></span><span></span><span></span><span></span><span></span>
      </div>
    `;
    return row;
  };

  root?.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) {
      return;
    }

    const row = target.closest<HTMLElement>("[data-color-row]");
    if (!row) {
      sync();
      return;
    }

    const picker = row.querySelector<HTMLInputElement>("[data-color-picker]");
    const hex = row.querySelector<HTMLInputElement>("[data-color-hex]");

    if (target.matches("[data-color-picker]") && hex) {
      hex.value = normalizeHex(target.value);
    }

    if (target.matches("[data-color-hex]") && picker) {
      picker.value = normalizeHex(target.value);
      target.value = normalizeHex(target.value);
    }

    sync();
  });

  root?.querySelector("[data-add-color]")?.addEventListener("click", () => {
    list?.append(createColorRow());
    sync();
  });

  root?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) {
      return;
    }

    const remove = target.closest<HTMLButtonElement>("[data-remove-color]");
    if (!remove || getRows().length <= 1) {
      return;
    }

    remove.closest("[data-color-row]")?.remove();
    sync();
  });

  root?.querySelectorAll<HTMLElement>("[data-accordion-trigger]").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const content = trigger.nextElementSibling as HTMLElement | null;
      const isOpen = trigger.getAttribute("aria-expanded") === "true";
      trigger.setAttribute("aria-expanded", String(!isOpen));
      if (content) {
        content.hidden = isOpen;
      }
    });
  });

  root?.querySelector("[data-open-export]")?.addEventListener("click", () => {
    renderExport();
    modal?.showModal();
  });

  root?.querySelector("[data-close-export]")?.addEventListener("click", () => modal?.close());
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) {
      modal.close();
    }
  });

  root?.querySelectorAll("[data-copy-export]").forEach((button) => {
    button.addEventListener("click", async () => {
      await navigator.clipboard?.writeText(renderExport());
    });
  });

  root?.querySelector("[data-download-export]")?.addEventListener("click", () => {
    const blob = new Blob([renderExport()], { type: "text/css" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = "framework-variables.css";
    link.click();
    URL.revokeObjectURL(url);
  });

  sync();
</script>

<style is:global>
  .framework-sidebar {
    display: grid;
    grid-template-rows: auto auto auto minmax(0, 1fr) auto;
    align-content: start;
    gap: 0.875rem;
    inline-size: 13.75rem;
    block-size: 100vh;
    border-inline-end: 1px solid var(--sidebar-border);
    padding: 0.75rem 0.625rem;
    background: #fbfcfe;
    color: var(--sidebar-foreground);
  }

  .framework-sidebar__header {
    display: grid;
    gap: 0.125rem;
  }

  .framework-sidebar__eyebrow,
  .framework-sidebar__title {
    margin: 0;
  }

  .framework-sidebar__eyebrow {
    color: var(--sidebar-muted);
    font-size: 0.6875rem;
    font-weight: 700;
    line-height: 1;
  }

  .framework-sidebar__title {
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.05;
  }

  .framework-sidebar__group,
  .framework-sidebar__accordion-content,
  .framework-sidebar__color-row {
    display: grid;
    gap: 0.5rem;
  }

  .framework-sidebar__color-row {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
  }

  .framework-sidebar__color-row .framework-sidebar__color-input,
  .framework-sidebar__color-row .framework-sidebar__color-scale {
    grid-column: 1 / -1;
  }

  .framework-sidebar__accordion-button {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 5.25rem auto;
    align-items: center;
    gap: 0.375rem;
    min-block-size: 2rem;
    border: 0;
    border-block-end: 1px solid var(--sidebar-border);
    padding: 0;
    background: transparent;
    color: var(--sidebar-foreground);
    font-size: 0.6875rem;
    font-weight: 800;
    text-align: start;
  }

  .framework-sidebar__accordion-button[aria-expanded="true"] .framework-sidebar__chevron {
    transform: rotate(180deg);
  }

  .framework-sidebar__accordion-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .framework-sidebar__chevron {
    color: var(--muted-foreground);
    transition: transform 160ms ease;
  }

  .framework-sidebar__accordion-content[hidden] {
    display: none;
  }

  .framework-sidebar__swatches {
    display: inline-flex;
    align-items: center;
    justify-self: end;
  }

  .framework-sidebar__summary {
    display: inline-flex;
    min-inline-size: 0;
    align-items: center;
    justify-content: end;
    justify-self: stretch;
  }

  .framework-sidebar__swatch,
  .framework-sidebar__count {
    display: grid;
    place-items: center;
    inline-size: 0.5rem;
    block-size: 0.5rem;
    border: 1px solid #ffffff;
    border-radius: 999px;
    background: var(--swatch);
    margin-inline-start: -0.125rem;
  }

  .framework-sidebar__count {
    inline-size: auto;
    border: 0;
    background: transparent;
    color: var(--sidebar-muted);
    font-size: 0.5625rem;
    font-weight: 700;
  }

  .framework-sidebar__color-list {
    display: grid;
    gap: 0.625rem;
  }

  .framework-sidebar__name-field {
    min-inline-size: 0;
  }

  .framework-sidebar__remove-button {
    display: grid;
    place-items: center;
    inline-size: 1.375rem;
    block-size: 1.375rem;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--muted-foreground);
  }

  .framework-sidebar__remove-button:hover:not(:disabled) {
    border-color: var(--border);
    background: var(--card);
    color: var(--foreground);
  }

  .framework-sidebar__remove-button:disabled {
    opacity: 0.28;
    cursor: default;
  }

  .framework-sidebar__name-input {
    inline-size: 100%;
    border: 0;
    border-block-end: 1px solid transparent;
    outline: 0;
    padding: 0;
    background: transparent;
    color: var(--sidebar-foreground);
    font-size: 0.6875rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .framework-sidebar__name-input:focus {
    border-block-end-color: var(--ring);
  }

  .framework-sidebar__color-input {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 0.375rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.375rem 0.5rem;
    background: var(--card);
  }

  .framework-sidebar__picker {
    inline-size: 1.375rem;
    block-size: 1.375rem;
    border: 0;
    padding: 0;
    background: transparent;
  }

  .framework-sidebar__picker::-webkit-color-swatch-wrapper {
    padding: 0;
  }

  .framework-sidebar__picker::-webkit-color-swatch {
    border: 0;
    border-radius: 0.25rem;
  }

  .framework-sidebar__hex-input {
    min-inline-size: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--sidebar-foreground);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .framework-sidebar__color-scale {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    overflow: hidden;
    block-size: 1.375rem;
    border-radius: var(--radius-sm);
  }

  .framework-sidebar__color-scale span {
    background: var(--step);
  }

  .framework-sidebar__add-button,
  .framework-sidebar__secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    min-block-size: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: #f8fafc;
    color: var(--sidebar-foreground);
    font-size: 0.6875rem;
    font-weight: 700;
  }

  .framework-sidebar__preview,
  .framework-sidebar__hint {
    overflow: hidden;
    color: var(--sidebar-muted);
    font-size: 0.625rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .framework-sidebar__hint {
    margin: 0;
    white-space: normal;
    line-height: 1.4;
  }

  .framework-sidebar__preview {
    inline-size: 100%;
    justify-self: stretch;
    text-align: end;
  }

  .framework-sidebar__spacer {
    min-block-size: 0;
  }

  .framework-sidebar__primary-button,
  .framework-sidebar__icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    min-block-size: 1.875rem;
    border-radius: var(--radius-sm);
    font-size: 0.6875rem;
    font-weight: 800;
  }

  .framework-sidebar__primary-button {
    border: 0;
    background: #111827;
    color: #ffffff;
  }

  .framework-sidebar__icon-button {
    inline-size: 1.875rem;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--muted-foreground);
  }

  .framework-sidebar__footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.5rem;
    align-self: end;
  }

  .framework-sidebar__modal {
    inline-size: min(34rem, calc(100vw - 2rem));
    border: 0;
    border-radius: var(--radius-md);
    padding: 0;
    background: transparent;
  }

  .framework-sidebar__modal::backdrop {
    background: color-mix(in srgb, #030712 34%, transparent);
  }

  .framework-sidebar__modal-card {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem;
    background: #ffffff;
    box-shadow: 0 1.5rem 4rem color-mix(in srgb, #030712 20%, transparent);
  }

  .framework-sidebar__modal-header,
  .framework-sidebar__modal-actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 0.75rem;
  }

