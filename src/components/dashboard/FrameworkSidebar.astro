---
import { ChevronDown, Plus } from "@lucide/astro";
import FrameworkAccordionSummary from "./FrameworkAccordionSummary.astro";
import FrameworkColorRow from "./FrameworkColorRow.astro";
import FrameworkExportDialog from "./FrameworkExportDialog.astro";

const ratios = [
  ["1.067", "Minor Second"],
  ["1.125", "Major Second"],
  ["1.200", "Minor Third"],
  ["1.250", "Major Third"],
  ["1.333", "Perfect Fourth"],
  ["1.500", "Perfect Fifth"],
];
---

<aside class="framework-settings" aria-label="Framework settings" data-framework-settings>
  <header class="framework-settings__header">
    <div><p>Tools /</p><h2>Framework</h2></div>
    <button type="button" data-framework-reset>Reset</button>
  </header>

  <section class="framework-viewport" aria-labelledby="framework-viewport-title">
    <header class="framework-card__header"><strong id="framework-viewport-title">Fluid viewport</strong><span data-viewport-range-label>320 → 1440 px</span></header>
    <div class="framework-field-pair">
      <label class="framework-field"><span>Minimum</span><span class="framework-control framework-control--unit"><input type="number" min="240" max="1920" step="1" value="320" data-fluid-min-width /><i>px</i></span></label>
      <label class="framework-field"><span>Maximum</span><span class="framework-control framework-control--unit"><input type="number" min="480" max="3840" step="1" value="1440" data-fluid-max-width /><i>px</i></span></label>
    </div>
  </section>

  <div class="framework-settings__accordions">
    <section class="framework-accordion" data-framework-accordion="colors">
      <button class="framework-accordion__trigger" type="button" aria-expanded="true" data-accordion-trigger>
        <span>Colors</span>
        <FrameworkAccordionSummary dataAttribute="data-color-summary" className="framework-color-summary"><i style="--summary-color:#2563EB"></i></FrameworkAccordionSummary>
        <ChevronDown size={13} stroke-width={2} />
      </button>
      <div class="framework-accordion__content" data-accordion-content>
        <label class="framework-field framework-field--stack"><span>Naming convention</span><span class="framework-control"><input type="text" value="color" data-color-convention /></span></label>
        <div class="framework-colors__list" data-color-list>
          <FrameworkColorRow name="Primary" value="#2563EB" removable={false} />
        </div>
        <template data-color-row-template><FrameworkColorRow name="Color __INDEX__" value="#7C3AED" /></template>
        <button class="framework-button framework-colors__add" type="button" data-add-color><Plus size={13} stroke-width={2} /> Add color</button>
      </div>
    </section>

    <section class="framework-accordion" data-framework-accordion="semantics">
      <button class="framework-accordion__trigger" type="button" aria-expanded="false" data-accordion-trigger>
        <span>Semantic colors</span>
        <FrameworkAccordionSummary dataAttribute="data-semantic-summary">6 roles</FrameworkAccordionSummary>
        <ChevronDown size={13} stroke-width={2} />
      </button>
      <div class="framework-accordion__content" hidden data-accordion-content>
        <div class="framework-card framework-semantic-fields">
          <header class="framework-card__header"><strong>Role mapping</strong><span>Palette tokens</span></header>
          <label class="framework-field framework-field--stack"><span>Naming convention</span><span class="framework-control"><input type="text" value="semantic" data-semantic-convention /></span><small hidden data-semantic-convention-error>Must differ from Colors. Using a safe semantic suffix.</small></label>
          {["primary","action","surface","text","border","focus"].map((role) => (
            <label class="framework-field framework-field--stack">
              <span>{role[0].toUpperCase() + role.slice(1)}</span>
              <span class="framework-control framework-control--select"><select aria-label={`${role} semantic color`} data-semantic-role={role}></select><ChevronDown size={13} /></span>
            </label>
          ))}
        </div>
      </div>
    </section>

    <section class="framework-accordion" data-framework-accordion="type">
      <button class="framework-accordion__trigger" type="button" aria-expanded="false" data-accordion-trigger>
        <span>Typography</span>
        <FrameworkAccordionSummary dataAttribute="data-type-summary">text · 16–18 px</FrameworkAccordionSummary>
        <ChevronDown size={13} stroke-width={2} />
      </button>
      <div class="framework-accordion__content" hidden data-accordion-content>
        <div class="framework-mode" role="tablist" aria-label="Typography scale mode">
          <button type="button" role="tab" aria-selected="true" data-system-mode="type" data-mode-value="automatic">Automatic</button>
          <button type="button" role="tab" aria-selected="false" data-system-mode="type" data-mode-value="manual">Manual</button>
        </div>
        <div class="framework-card" data-system-auto="type">
          <header class="framework-card__header"><strong>Fluid scale</strong><span data-type-range-label>Shared viewport</span></header>
          <label class="framework-field framework-field--stack"><span>Naming convention</span><span class="framework-control"><input type="text" value="text" data-type-name /></span></label>
          <div class="framework-field-pair">
            <label class="framework-field"><span>Minimum</span><span class="framework-control framework-control--unit"><input type="number" min="10" max="24" step="1" value="16" data-type-min /><i>px</i></span></label>
            <label class="framework-field"><span>Maximum</span><span class="framework-control framework-control--unit"><input type="number" min="12" max="32" step="1" value="18" data-type-max /><i>px</i></span></label>
          </div>
          <label class="framework-field framework-field--stack"><span>Scale ratio <small>Min viewport</small></span><span class="framework-control framework-control--select"><select data-type-min-ratio>{ratios.map(([value, name]) => <option value={value} selected={value === "1.125"}>{name} · {value}</option>)}</select><ChevronDown size={13} /></span></label>
          <label class="framework-field framework-field--stack"><span>Scale ratio <small>Max viewport</small></span><span class="framework-control framework-control--select"><select data-type-max-ratio>{ratios.map(([value, name]) => <option value={value} selected={value === "1.333"}>{name} · {value}</option>)}</select><ChevronDown size={13} /></span></label>
          <label class="framework-field framework-field--inline"><span>Base scale index<small>Anchor token</small></span><span class="framework-control framework-control--select framework-control--short"><select data-type-index><option>xs</option><option>s</option><option selected>m</option><option>l</option><option>xl</option></select><ChevronDown size={13} /></span></label>
        </div>
        <div class="framework-manual" hidden data-system-manual="type">
          <p>Set each token directly.</p>
          {[["xs",13],["s",14],["m",16],["l",20],["xl",25],["2xl",32],["3xl",40],["4xl",50]].map(([token, value]) => <label><span>{token}</span><input type="number" step="1" value={value} data-manual-type={token} /><i>px</i></label>)}
        </div>
      </div>
    </section>

    <section class="framework-accordion" data-framework-accordion="radius">
      <button class="framework-accordion__trigger" type="button" aria-expanded="false" data-accordion-trigger>
        <span>Border radius</span><FrameworkAccordionSummary dataAttribute="data-radius-summary">radius · 4–8 px</FrameworkAccordionSummary><ChevronDown size={13} stroke-width={2} />
      </button>
      <div class="framework-accordion__content" hidden data-accordion-content>
        <div class="framework-mode" role="tablist" aria-label="Border radius scale mode">
          <button type="button" role="tab" aria-selected="true" data-system-mode="radius" data-mode-value="automatic">Automatic</button>
          <button type="button" role="tab" aria-selected="false" data-system-mode="radius" data-mode-value="manual">Manual</button>
        </div>
        <div class="framework-card" data-system-auto="radius">
          <header class="framework-card__header"><strong>Fluid scale</strong><span data-radius-range-label>Shared viewport</span></header>
          <label class="framework-field framework-field--stack"><span>Naming convention</span><span class="framework-control"><input type="text" value="radius" data-radius-name /></span></label>
          <div class="framework-field-pair">
            <label class="framework-field"><span>Minimum</span><span class="framework-control framework-control--unit"><input type="number" min="0" max="32" step="1" value="4" data-radius-min /><i>px</i></span></label>
            <label class="framework-field"><span>Maximum</span><span class="framework-control framework-control--unit"><input type="number" min="4" max="64" step="1" value="8" data-radius-max /><i>px</i></span></label>
          </div>
          <label class="framework-field framework-field--stack"><span>Scale ratio <small>Min viewport</small></span><span class="framework-control framework-control--select"><select data-radius-min-ratio>{ratios.map(([value, name]) => <option value={value} selected={value === "1.250"}>{name} · {value}</option>)}</select><ChevronDown size={13} /></span></label>
          <label class="framework-field framework-field--stack"><span>Scale ratio <small>Max viewport</small></span><span class="framework-control framework-control--select"><select data-radius-max-ratio>{ratios.map(([value, name]) => <option value={value} selected={value === "1.500"}>{name} · {value}</option>)}</select><ChevronDown size={13} /></span></label>
          <label class="framework-field framework-field--inline"><span>Base scale index<small>Anchor token</small></span><span class="framework-control framework-control--select framework-control--short"><select data-radius-index><option>xs</option><option>s</option><option selected>m</option><option>l</option><option>xl</option></select><ChevronDown size={13} /></span></label>
          <label class="framework-field framework-field--inline"><span>Include full<small>Add pill token</small></span><input class="framework-switch" type="checkbox" checked data-radius-full /></label>
        </div>
        <div class="framework-manual" hidden data-system-manual="radius">
          <p>Set each token directly.</p>
          {[["xs",2],["s",4],["m",8],["l",12],["xl",20]].map(([token, value]) => <label><span>{token}</span><input type="number" step="1" value={value} data-manual-radius={token} /><i>px</i></label>)}
        </div>
      </div>
    </section>

    <section class="framework-accordion" data-framework-accordion="spacing">
      <button class="framework-accordion__trigger" type="button" aria-expanded="false" data-accordion-trigger>
        <span>Spacing</span><FrameworkAccordionSummary dataAttribute="data-spacing-summary">space · 16–20 px</FrameworkAccordionSummary><ChevronDown size={13} stroke-width={2} />
      </button>
      <div class="framework-accordion__content" hidden data-accordion-content>
        <div class="framework-mode" role="tablist" aria-label="Spacing scale mode">
          <button type="button" role="tab" aria-selected="true" data-system-mode="spacing" data-mode-value="automatic">Automatic</button>
          <button type="button" role="tab" aria-selected="false" data-system-mode="spacing" data-mode-value="manual">Manual</button>
        </div>
        <div class="framework-card" data-system-auto="spacing">
          <header class="framework-card__header"><strong>Fluid scale</strong><span data-spacing-range-label>Shared viewport</span></header>
          <label class="framework-field framework-field--stack"><span>Naming convention</span><span class="framework-control"><input type="text" value="space" data-spacing-name /></span></label>
          <div class="framework-field-pair">
            <label class="framework-field"><span>Minimum</span><span class="framework-control framework-control--unit"><input type="number" min="4" max="64" step="1" value="16" data-spacing-min /><i>px</i></span></label>
            <label class="framework-field"><span>Maximum</span><span class="framework-control framework-control--unit"><input type="number" min="4" max="96" step="1" value="20" data-spacing-max /><i>px</i></span></label>
          </div>
          <label class="framework-field framework-field--stack"><span>Scale ratio <small>Min viewport</small></span><span class="framework-control framework-control--select"><select data-spacing-min-ratio>{ratios.map(([value, name]) => <option value={value} selected={value === "1.200"}>{name} · {value}</option>)}</select><ChevronDown size={13} /></span></label>
          <label class="framework-field framework-field--stack"><span>Scale ratio <small>Max viewport</small></span><span class="framework-control framework-control--select"><select data-spacing-max-ratio>{ratios.map(([value, name]) => <option value={value} selected={value === "1.333"}>{name} · {value}</option>)}</select><ChevronDown size={13} /></span></label>
          <label class="framework-field framework-field--inline"><span>Base scale index<small>Anchor token</small></span><span class="framework-control framework-control--select framework-control--short"><select data-spacing-index><option>xs</option><option>s</option><option selected>m</option><option>l</option><option>xl</option></select><ChevronDown size={13} /></span></label>
        </div>
        <div class="framework-manual" hidden data-system-manual="spacing">
          <p>Set each token directly.</p>
          {[["4xs",2],["3xs",4],["2xs",6],["xs",8],["s",12],["m",16],["l",24],["xl",32],["2xl",48],["3xl",64],["4xl",96]].map(([token, value]) => <label><span>{token}</span><input type="number" step="1" value={value} data-manual-spacing={token} /><i>px</i></label>)}
        </div>
      </div>
    </section>
  </div>
  <FrameworkExportDialog />
</aside>

<script>
  const root = document.querySelector<HTMLElement>("[data-framework-settings]");
  const colorList = root?.querySelector<HTMLElement>("[data-color-list]");
  const colorTemplate = root?.querySelector<HTMLTemplateElement>("[data-color-row-template]");
  let colorCount = root?.querySelectorAll("[data-color-row]").length ?? 0;

  const fallbackOklch = { l: .623, c: .214, h: 259.8 };
  const normalizeHex = (value: string) => {
    const cleaned=value.trim().replace(/^#/,"");
    if (/^[0-9a-f]{3}$/i.test(cleaned)) return `#${cleaned.split("").map((character)=>character.repeat(2)).join("")}`.toUpperCase();
    if (/^[0-9a-f]{6}$/i.test(cleaned)) return `#${cleaned}`.toUpperCase();
    return "#2563EB";
  };
  const parseOklch = (value: string) => {
    const match = value.trim().match(/^oklch\(\s*([\d.]+)(%)?\s+([\d.]+)\s+([\d.]+)(?:deg)?(?:\s*\/\s*[\d.]+%?)?\s*\)$/i);
    if (!match) return fallbackOklch;
    return { l: Math.max(0, Math.min(1, Number(match[1]) / (match[2] ? 100 : Number(match[1]) > 1 ? 100 : 1))), c: Math.max(0, Number(match[3])), h: ((Number(match[4]) % 360) + 360) % 360 };
  };
  const formatOklch = ({ l, c, h }: {l:number;c:number;h:number}) => `oklch(${Number((l * 100).toFixed(1))}% ${Number(c.toFixed(3))} ${Number(h.toFixed(1))})`;
  const hexToOklch = (hex: string) => {
    const cleaned = hex.replace("#", "");
    const rgb = [0,2,4].map((offset) => Number.parseInt(cleaned.slice(offset,offset+2),16) / 255).map((channel) => channel <= .04045 ? channel / 12.92 : Math.pow((channel + .055) / 1.055, 2.4));
    const l = .4122214708*rgb[0]+.5363325363*rgb[1]+.0514459929*rgb[2];
    const m = .2119034982*rgb[0]+.6806995451*rgb[1]+.1073969566*rgb[2];
    const s = .0883024619*rgb[0]+.2817188376*rgb[1]+.6299787005*rgb[2];
    const l3=Math.cbrt(l),m3=Math.cbrt(m),s3=Math.cbrt(s);
    const L=.2104542553*l3+.793617785*m3-.0040720468*s3;
    const a=1.9779984951*l3-2.428592205*m3+.4505937099*s3;
    const b=.0259040371*l3+.7827717662*m3-.808675766*s3;
    return formatOklch({l:L,c:Math.hypot(a,b),h:(Math.atan2(b,a)*180/Math.PI+360)%360});
  };
  const scaleFor = (value: string) => {
    const color=parseOklch(value);
    const levels=[
      .98893,
      .953806,
      .88274,
      color.l,
      color.l*.74,
      color.l*.5,
      color.l*.28,
    ];
    const referenceChromaFactors=[.01614,.08723,.22364];
    const referenceHueOffsets=[12.90372,12.56369,11.79823];
    return levels.map((lightness,index) => {
      if (index<3) return formatOklch({l:lightness,c:color.c*referenceChromaFactors[index],h:(color.h+referenceHueOffsets[index])%360});
      const chromaFactor=Math.min(1,Math.max(.18,1-Math.abs(lightness-.55)/.55));
      return formatOklch({l:lightness,c:color.c*chromaFactor,h:color.h});
    });
  };
  const tokenSlug = (value: string) => value.toLowerCase().trim().replace(/[^a-z0-9]+/g,"-").replace(/^-|-$/g,"") || "token";
  const colorSlug = (value: string) => tokenSlug(value).replace(/^color-/,"").replace(/-color$/,"") || "token";
  type GeneratedColor = { name:string; value:string; scale:string[]; variable:string; dtcgPath:string };
  type SemanticMapping = { role:string; reference:string; value:string; label:string; variable:string; dtcgGroup:string; dtcgReference?:string };
  const colorRows = () => [...(root?.querySelectorAll<HTMLElement>("[data-color-row]") ?? [])];
  const STORAGE_KEY = "techies-tools:framework:v1";
  const CONTROL_ATTRIBUTES = [
    "data-fluid-min-width", "data-fluid-max-width",
    "data-color-convention", "data-semantic-convention",
    "data-type-name", "data-type-min", "data-type-max", "data-type-min-ratio", "data-type-max-ratio", "data-type-index",
    "data-radius-name", "data-radius-min", "data-radius-max", "data-radius-min-ratio", "data-radius-max-ratio", "data-radius-index", "data-radius-full",
    "data-spacing-name", "data-spacing-min", "data-spacing-max", "data-spacing-min-ratio", "data-spacing-max-ratio", "data-spacing-index",
  ];
  const manualAttributes = ["data-manual-type", "data-manual-radius", "data-manual-spacing"];
  const appendColorRow = (name: string, hex: string) => {
    if (!colorTemplate || !colorList) return;
    colorCount += 1;
    const fragment = colorTemplate.content.cloneNode(true) as DocumentFragment;
    fragment.querySelectorAll<HTMLElement>("*").forEach((element) => {
      ["aria-label", "value"].forEach((attribute) => {
        const current = element.getAttribute(attribute);
        if (current?.includes("__INDEX__")) element.setAttribute(attribute, current.replaceAll("__INDEX__", String(colorCount)));
      });
    });
    const row = fragment.querySelector<HTMLElement>("[data-color-row]");
    const nameInput = row?.querySelector<HTMLInputElement>("[data-color-name]");
    const hexInput = row?.querySelector<HTMLInputElement>("[data-color-hex]");
    const picker = row?.querySelector<HTMLInputElement>("[data-color-picker]");
    const normalized = normalizeHex(hex);
    if (nameInput) nameInput.value = name;
    if (hexInput) hexInput.value = normalized;
    if (picker) picker.value = normalized;
    colorList.append(fragment);
  };
  const collectState = () => {
    const controls: Record<string, string | boolean> = {};
    CONTROL_ATTRIBUTES.forEach((attribute) => {
      const control = root?.querySelector<HTMLInputElement | HTMLSelectElement>(`[${attribute}]`);
      if (control) controls[attribute] = control instanceof HTMLInputElement && control.type === "checkbox" ? control.checked : control.value;
    });
    const manual: Record<string, string> = {};
    manualAttributes.forEach((attribute) => root?.querySelectorAll<HTMLInputElement>(`[${attribute}]`).forEach((control) => { manual[`${attribute}:${control.getAttribute(attribute)}`] = control.value; }));
    const modes: Record<string, string> = {};
    root?.querySelectorAll<HTMLButtonElement>("[data-system-mode][aria-selected='true']").forEach((button) => { modes[button.dataset.systemMode ?? "type"] = button.dataset.modeValue ?? "automatic"; });
    return {
      version: 1,
      controls,
      manual,
      modes,
      semantics: Object.fromEntries([...(root?.querySelectorAll<HTMLSelectElement>("[data-semantic-role]") ?? [])].map((select) => [select.dataset.semanticRole ?? "primary", select.value])),
      openAccordion: root?.querySelector<HTMLElement>("[data-framework-accordion] [data-accordion-trigger][aria-expanded='true']")?.closest<HTMLElement>("[data-framework-accordion]")?.dataset.frameworkAccordion ?? null,
      colors: colorRows().map((row, index) => ({ name: row.querySelector<HTMLInputElement>("[data-color-name]")?.value || `Color ${index + 1}`, hex: normalizeHex(row.querySelector<HTMLInputElement>("[data-color-hex]")?.value || "#2563EB") })),
    };
  };
  type FrameworkState = ReturnType<typeof collectState>;
  const applyState = (state: FrameworkState) => {
    if (!root || state.version !== 1) return;
    Object.entries(state.controls ?? {}).forEach(([attribute, value]) => {
      const control = root.querySelector<HTMLInputElement | HTMLSelectElement>(`[${attribute}]`);
      if (!control) return;
      if (control instanceof HTMLInputElement && control.type === "checkbox") control.checked = Boolean(value);
      else control.value = String(value);
    });
    Object.entries(state.manual ?? {}).forEach(([key, value]) => {
      const separator = key.indexOf(":");
      const attribute = key.slice(0, separator);
      const token = key.slice(separator + 1);
      const control = root.querySelector<HTMLInputElement>(`[${attribute}="${CSS.escape(token)}"]`);
      if (control) control.value = value;
    });
    const firstRow = colorRows()[0];
    colorRows().slice(1).forEach((row) => row.remove());
    colorCount = 1;
    const colors = (state.colors?.length ? state.colors : [{ name:"Primary", hex:"#2563EB" }]).map((color, index) => ({
      ...color,
      name: index === 0 && color.name.trim().toLowerCase() === "primary color" ? "Primary" : color.name,
    }));
    const firstName = firstRow?.querySelector<HTMLInputElement>("[data-color-name]");
    const firstHex = firstRow?.querySelector<HTMLInputElement>("[data-color-hex]");
    const firstPicker = firstRow?.querySelector<HTMLInputElement>("[data-color-picker]");
    if (firstName) firstName.value = colors[0].name;
    if (firstHex) firstHex.value = normalizeHex(colors[0].hex);
    if (firstPicker) firstPicker.value = normalizeHex(colors[0].hex);
    colors.slice(1).forEach((color) => appendColorRow(color.name, color.hex));
    root.querySelectorAll<HTMLSelectElement>("[data-semantic-role]").forEach((select) => {
      select.dataset.pendingValue = state.semantics?.[select.dataset.semanticRole ?? "primary"] ?? "";
    });
    root.querySelectorAll<HTMLButtonElement>("[data-system-mode]").forEach((button) => {
      const selected = (state.modes?.[button.dataset.systemMode ?? "type"] ?? "automatic") === button.dataset.modeValue;
      button.setAttribute("aria-selected", String(selected));
    });
    ["type", "radius", "spacing"].forEach((system) => {
      const automatic = (state.modes?.[system] ?? "automatic") === "automatic";
      const automaticPanel = root.querySelector<HTMLElement>(`[data-system-auto="${system}"]`);
      const manualPanel = root.querySelector<HTMLElement>(`[data-system-manual="${system}"]`);
      if (automaticPanel) automaticPanel.hidden = !automatic;
      if (manualPanel) manualPanel.hidden = automatic;
    });
    root.querySelectorAll<HTMLElement>("[data-framework-accordion]").forEach((section) => {
      const open = section.dataset.frameworkAccordion === state.openAccordion;
      section.querySelector<HTMLButtonElement>("[data-accordion-trigger]")?.setAttribute("aria-expanded", String(open));
      const content = section.querySelector<HTMLElement>("[data-accordion-content]");
      if (content) content.hidden = !open;
    });
  };
  const persistState = () => {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(collectState())); } catch { /* Storage may be unavailable. */ }
  };
  const openInitialColors = () => {
    root?.querySelectorAll<HTMLElement>("[data-framework-accordion]").forEach((section) => {
      const open = section.dataset.frameworkAccordion === "colors";
      section.querySelector<HTMLButtonElement>("[data-accordion-trigger]")?.setAttribute("aria-expanded", String(open));
      const content = section.querySelector<HTMLElement>("[data-accordion-content]");
      if (content) content.hidden = !open;
    });
  };
  const sharedViewport = () => {
    const minWidthPx = Number(root?.querySelector<HTMLInputElement>("[data-fluid-min-width]")?.value || 320);
    const maxInput = root?.querySelector<HTMLInputElement>("[data-fluid-max-width]");
    const maxWidthPx = Math.max(minWidthPx + 1, Number(maxInput?.value || 1440));
    if (maxInput) maxInput.value = String(maxWidthPx);
    const label = root?.querySelector<HTMLElement>("[data-viewport-range-label]");
    if (label) label.textContent = `${minWidthPx} → ${maxWidthPx} px`;
    return { minWidth:minWidthPx/16, maxWidth:maxWidthPx/16 };
  };
  const viewportVariables = () => {
    const {minWidth,maxWidth}=sharedViewport();
    return { "--fluid-min-viewport":`${minWidth}rem`, "--fluid-max-viewport":`${maxWidth}rem`, "--section-min-width":`${minWidth}rem`, "--section-max-width":`${maxWidth}rem` };
  };
  const activeMode = (system: string) => root?.querySelector<HTMLButtonElement>(`[data-system-mode="${system}"][aria-selected="true"]`)?.dataset.modeValue ?? "automatic";
  const manualTokens = (system: "type" | "radius" | "spacing") => [...(root?.querySelectorAll<HTMLInputElement>(`[data-manual-${system}]`) ?? [])].map((control) => {
    const token = control.getAttribute(`data-manual-${system}`) || "m";
    const value = Math.max(0, Number(control.value || 0)) / 16;
    return { token, min:Number(value.toFixed(4)), max:Number(value.toFixed(4)) };
  });

  const semanticOptions = (colors: GeneratedColor[]) => {
    const options: Array<{label:string;reference:string;value:string;dtcgReference?:string}> = [];
    colors.forEach((color) => {
      const variable=color.variable;
      const shades=[
        ["Lightest",`${variable}-lightest`,color.scale[0],`${color.dtcgPath}.lightest`],
        ["Lighter",`${variable}-lighter`,color.scale[1],`${color.dtcgPath}.lighter`],
        ["Light",`${variable}-light`,color.scale[2],`${color.dtcgPath}.light`],
        ["Base",variable,color.value,`${color.dtcgPath}.value`],
        ["Dark",`${variable}-dark`,color.scale[4],`${color.dtcgPath}.dark`],
        ["Darker",`${variable}-darker`,color.scale[5],`${color.dtcgPath}.darker`],
        ["Darkest",`${variable}-darkest`,color.scale[6],`${color.dtcgPath}.darkest`],
      ];
      shades.forEach(([shade,reference,value,dtcgReference]) => options.push({ label:`${color.name} / ${shade}`, reference, value, dtcgReference }));
    });
    options.push(
      {label:"Black",reference:"oklch(0% 0 0)",value:"oklch(0% 0 0)"},
      {label:"White",reference:"oklch(100% 0 0)",value:"oklch(100% 0 0)"},
    );
    return options;
  };

  const refreshSemanticOptions = (colors: GeneratedColor[]) => {
    const options=semanticOptions(colors);
    const primaryBase=options.find((option)=>option.label.endsWith(" / Base"))?.reference ?? "oklch(0% 0 0)";
    const defaults: Record<string,string> = {
      primary:primaryBase,
      action:primaryBase,
      surface:options.find((option)=>option.label.endsWith(" / Lightest"))?.reference ?? "oklch(100% 0 0)",
      text:"oklch(0% 0 0)",
      border:options.find((option)=>option.label.endsWith(" / Light"))?.reference ?? primaryBase,
      focus:primaryBase,
    };
    root?.querySelectorAll<HTMLSelectElement>("[data-semantic-role]").forEach((select) => {
      const role=select.dataset.semanticRole ?? "primary";
      const requested=select.dataset.pendingValue || select.value || defaults[role];
      const requestedLabel=select.selectedOptions[0]?.textContent;
      select.replaceChildren(...options.map((item) => {
        const option=new Option(item.label,item.reference);
        option.dataset.colorValue=item.value;
        if (item.dtcgReference) option.dataset.dtcgReference=item.dtcgReference;
        return option;
      }));
      const preserved=options.find((option)=>option.reference===requested) ?? options.find((option)=>option.label===requestedLabel);
      select.value=preserved?.reference ?? defaults[role];
      delete select.dataset.pendingValue;
    });
  };

  const publishSemantics = () => {
    const semantics: Record<string,SemanticMapping> = {};
    const input=root?.querySelector<HTMLInputElement>("[data-semantic-convention]");
    const requestedConvention=tokenSlug(input?.value || "semantic");
    const colorConvention=tokenSlug(root?.querySelector<HTMLInputElement>("[data-color-convention]")?.value || "color");
    const hasCollision=requestedConvention===colorConvention;
    const convention=hasCollision ? `${requestedConvention}-semantic` : requestedConvention;
    input?.setCustomValidity(hasCollision ? "Semantic naming convention must differ from Colors." : "");
    input?.setAttribute("aria-invalid",String(hasCollision));
    const error=root?.querySelector<HTMLElement>("[data-semantic-convention-error]");
    if (error) error.hidden=!hasCollision;
    root?.querySelectorAll<HTMLSelectElement>("[data-semantic-role]").forEach((select) => {
      const option=select.selectedOptions[0];
      const role=select.dataset.semanticRole ?? "primary";
      if (!option) return;
      semantics[role]={ role, reference:select.value, value:option.dataset.colorValue ?? select.value, label:option.textContent ?? role, variable:`--${convention}-${role}`, dtcgGroup:convention, dtcgReference:option.dataset.dtcgReference };
    });
    const summary=root?.querySelector<HTMLElement>("[data-semantic-summary]");
    if (summary) summary.textContent=`${Object.keys(semantics).length} roles`;
    window.dispatchEvent(new CustomEvent("framework-preview:update", { detail:{ semantics } }));
  };

  const publishColors = () => {
    const convention=tokenSlug(root?.querySelector<HTMLInputElement>("[data-color-convention]")?.value || "color");
    const colors = colorRows().map((row, index) => {
      const nameInput = row.querySelector<HTMLInputElement>("[data-color-name]");
      const hexInput = row.querySelector<HTMLInputElement>("[data-color-hex]");
      const picker = row.querySelector<HTMLInputElement>("[data-color-picker]");
      const hex = normalizeHex(hexInput?.value ?? picker?.value ?? "#2563EB");
      const value = hexToOklch(hex);
      const name = nameInput?.value.trim() || `Color ${index + 1}`;
      if (hexInput) hexInput.value = hex;
      if (picker) picker.value = hex;
      const scale = scaleFor(value);
      const scaleNames=["Lightest","Lighter","Light","Base","Dark","Darker","Darkest"];
      row.querySelectorAll<HTMLElement>("[data-color-scale] span").forEach((item, step) => {
        item.style.setProperty("--color-step", scale[step]);
        item.title=`${scaleNames[step]}: ${scale[step]}`;
        item.setAttribute("aria-label",`${scaleNames[step]} ${scale[step]}`);
      });
      const slug=colorSlug(name);
      return { name, value, scale, variable:`--${convention}-${slug}`, dtcgPath:`${convention}.${slug}` };
    });
    refreshSemanticOptions(colors);
    const summary = root?.querySelector<HTMLElement>("[data-color-summary]");
    if (summary) {
      summary.innerHTML = colors.slice(0, 6).map((color) => `<i style="--summary-color:${color.value}"></i>`).join("");
      summary.setAttribute("aria-label", colors.map((color) => color.name).join(", "));
    }
    colorRows().forEach((row) => { const remove = row.querySelector<HTMLButtonElement>("[data-remove-color]"); if (remove) remove.disabled = colors.length === 1; });
    window.dispatchEvent(new CustomEvent("framework-preview:update", { detail: { primary: colors[0]?.value, colors } }));
    publishSemantics();
  };

  const publishType = () => {
    const name = root?.querySelector<HTMLInputElement>("[data-type-name]")?.value || "text";
    const minPx = Number(root?.querySelector<HTMLInputElement>("[data-type-min]")?.value || 16);
    const maxPx = Number(root?.querySelector<HTMLInputElement>("[data-type-max]")?.value || 18);
    const min = minPx/16;
    const max = maxPx/16;
    const minRatio = root?.querySelector<HTMLSelectElement>("[data-type-min-ratio]")?.value || "1.125";
    const maxRatio = root?.querySelector<HTMLSelectElement>("[data-type-max-ratio]")?.value || "1.333";
    const baseIndex = root?.querySelector<HTMLSelectElement>("[data-type-index]")?.value || "m";
    const {minWidth,maxWidth}=sharedViewport();
    const summary = root?.querySelector<HTMLElement>("[data-type-summary]");
    const range = root?.querySelector<HTMLElement>("[data-type-range-label]");
    const manualRange = activeMode("type") === "manual" ? manualTokens("type").map((token) => token.min * 16) : null;
    if (summary) summary.textContent = `${name} · ${manualRange ? `${Math.min(...manualRange)}–${Math.max(...manualRange)}` : `${minPx}–${maxPx}`} px`;
    if (range) range.textContent = "Shared viewport";
    const mode = activeMode("type");
    const tokens = mode === "manual" ? manualTokens("type") : undefined;
    const variables = { ...viewportVariables(), ...(tokens ? Object.fromEntries(tokens.map((token) => [`--${name}-${token.token}`, `${token.min}rem`])) : {}) };
    const baseToken = tokens?.find((token) => token.token === "m");
    const type = { label:name, family:"Inter", weight:"500", min:`${baseToken?.min ?? min}rem`, max:`${baseToken?.max ?? max}rem`, minRatio, maxRatio, baseIndex, minWidth, maxWidth, mode, tokens };
    window.dispatchEvent(new CustomEvent("framework-preview:update", { detail: { variables, type } }));
  };

  const publishRadius = () => {
    const name = root?.querySelector<HTMLInputElement>("[data-radius-name]")?.value || "radius";
    const minPx = Number(root?.querySelector<HTMLInputElement>("[data-radius-min]")?.value || 4);
    const maxPx = Number(root?.querySelector<HTMLInputElement>("[data-radius-max]")?.value || 8);
    const min = minPx/16;
    const max = maxPx/16;
    const minRatio = Number(root?.querySelector<HTMLSelectElement>("[data-radius-min-ratio]")?.value || 1.25);
    const maxRatio = Number(root?.querySelector<HTMLSelectElement>("[data-radius-max-ratio]")?.value || 1.5);
    const baseIndex = root?.querySelector<HTMLSelectElement>("[data-radius-index]")?.value || "m";
    const {minWidth,maxWidth}=sharedViewport();
    const includeFull = root?.querySelector<HTMLInputElement>("[data-radius-full]")?.checked ?? true;
    const anchor = Math.max(0, ["xs","s","m","l","xl"].indexOf(baseIndex));
    const mode = activeMode("radius");
    const tokens = mode === "manual" ? manualTokens("radius") : ["xs","s","m","l","xl"].map((token, index) => { const step=index-anchor; const minValue=min*Math.pow(minRatio,step); const maxValue=Math.max(minValue,max*Math.pow(maxRatio,step)); return { token, min:Number(minValue.toFixed(2)), max:Number(maxValue.toFixed(2)) }; });
    if (includeFull) tokens.push({ token:"full", min:999, max:999 });
    const summary = root?.querySelector<HTMLElement>("[data-radius-summary]");
    const range = root?.querySelector<HTMLElement>("[data-radius-range-label]");
    const manualRange = mode === "manual" ? tokens.filter((token) => token.token !== "full").map((token) => token.min * 16) : null;
    if (summary) summary.textContent = `${name} · ${manualRange ? `${Math.min(...manualRange)}–${Math.max(...manualRange)}` : `${minPx}–${maxPx}`} px`;
    if (range) range.textContent = "Shared viewport";
    const variables = viewportVariables();
    window.dispatchEvent(new CustomEvent("framework-preview:update", { detail: { variables, radius:`${tokens.find((token) => token.token === "m")?.max ?? min}rem`, radii:{ name, tokens, minWidth, maxWidth, mode } } }));
  };

  const publishSpacing = () => {
    const name = root?.querySelector<HTMLInputElement>("[data-spacing-name]")?.value || "space";
    const minPx = Number(root?.querySelector<HTMLInputElement>("[data-spacing-min]")?.value || 16);
    const maxPx = Number(root?.querySelector<HTMLInputElement>("[data-spacing-max]")?.value || 20);
    const min = minPx/16;
    const max = maxPx/16;
    const minRatio = Number(root?.querySelector<HTMLSelectElement>("[data-spacing-min-ratio]")?.value || 1.2);
    const maxRatio = Number(root?.querySelector<HTMLSelectElement>("[data-spacing-max-ratio]")?.value || 1.333);
    const baseIndex = root?.querySelector<HTMLSelectElement>("[data-spacing-index]")?.value || "m";
    const {minWidth,maxWidth}=sharedViewport();
    const tokenNames = ["4xs","3xs","2xs","xs","s","m","l","xl","2xl","3xl","4xl"];
    const anchor = Math.max(0, tokenNames.indexOf(baseIndex));
    const mode = activeMode("spacing");
    const spacing = mode === "manual" ? manualTokens("spacing") : tokenNames.map((token, index) => { const step=index-anchor; const minValue=Math.max(.0625,min*Math.pow(minRatio,step)); const maxValue=Math.max(minValue,max*Math.pow(maxRatio,step)); return { token, min:Number(minValue.toFixed(3)), max:Number(maxValue.toFixed(3)) }; });
    const summary = root?.querySelector<HTMLElement>("[data-spacing-summary]");
    const range = root?.querySelector<HTMLElement>("[data-spacing-range-label]");
    const manualRange = mode === "manual" ? spacing.map((token) => token.min * 16) : null;
    if (summary) summary.textContent = `${name} · ${manualRange ? `${Math.min(...manualRange)}–${Math.max(...manualRange)}` : `${minPx}–${maxPx}`} px`;
    if (range) range.textContent = "Shared viewport";
    const variables = viewportVariables();
    window.dispatchEvent(new CustomEvent("framework-preview:update", { detail: { variables, spacing:{ name, tokens:spacing, minWidth, maxWidth, mode } } }));
  };

  const publishAll = () => { publishColors(); publishType(); publishRadius(); publishSpacing(); };
  publishColors();
  const defaultState = collectState();
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) applyState(JSON.parse(saved));
  } catch { /* Invalid or unavailable storage falls back to defaults. */ }
  openInitialColors();
  window.addEventListener("framework-export:request", publishAll);
  root?.querySelectorAll<HTMLButtonElement>("[data-accordion-trigger]").forEach((trigger) => trigger.addEventListener("click", () => {
    const targetSection = trigger.closest<HTMLElement>("[data-framework-accordion]");
    const willOpen = trigger.getAttribute("aria-expanded") !== "true";
    root.querySelectorAll<HTMLElement>("[data-framework-accordion]").forEach((section) => {
      const button = section.querySelector<HTMLButtonElement>("[data-accordion-trigger]");
      const content = section.querySelector<HTMLElement>("[data-accordion-content]");
      const open = section === targetSection && willOpen;
      button?.setAttribute("aria-expanded", String(open));
      if (content) content.hidden = !open;
    });
    persistState();
  }));

  root?.querySelectorAll<HTMLButtonElement>("[data-system-mode]").forEach((button) => button.addEventListener("click", () => {
    const system = button.dataset.systemMode ?? "type";
    root.querySelectorAll<HTMLButtonElement>(`[data-system-mode="${system}"]`).forEach((item) => item.setAttribute("aria-selected", String(item === button)));
    const automatic = button.dataset.modeValue === "automatic";
    const automaticPanel = root.querySelector<HTMLElement>(`[data-system-auto="${system}"]`);
    const manualPanel = root.querySelector<HTMLElement>(`[data-system-manual="${system}"]`);
    if (automaticPanel) automaticPanel.hidden = !automatic;
    if (manualPanel) manualPanel.hidden = automatic;
    if (system === "type") publishType();
    if (system === "radius") publishRadius();
    if (system === "spacing") publishSpacing();
    persistState();
  }));

  root?.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement || target instanceof HTMLSelectElement)) return;
    if (target instanceof HTMLInputElement && target.matches("[data-fluid-min-width],[data-fluid-max-width]")) { publishAll(); persistState(); return; }
    if (target instanceof HTMLInputElement && target.matches("[data-color-convention]")) { publishColors(); persistState(); return; }
    if (target instanceof HTMLInputElement && target.matches("[data-semantic-convention]")) { publishSemantics(); persistState(); return; }
    const row = target.closest<HTMLElement>("[data-color-row]");
    if (row && target instanceof HTMLInputElement) {
      const picker = row.querySelector<HTMLInputElement>("[data-color-picker]");
      const hex = row.querySelector<HTMLInputElement>("[data-color-hex]");
      if (target.matches("[data-color-picker]") && hex) hex.value = normalizeHex(target.value);
      if (target.matches("[data-color-hex]")) {
        const complete = /^#?[0-9a-f]{3}(?:[0-9a-f]{3})?$/i.test(target.value.trim());
        if (!complete) return;
        if (picker) picker.value = normalizeHex(target.value);
      }
      publishColors();
      persistState();
      return;
    }
    if (target.closest("[data-framework-accordion='type']")) publishType();
    if (target.closest("[data-framework-accordion='radius']")) publishRadius();
    if (target.closest("[data-framework-accordion='spacing']")) publishSpacing();
    persistState();
  });
  root?.addEventListener("change", () => { publishAll(); persistState(); });
  root?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    const remove = target.closest<HTMLButtonElement>("[data-remove-color]");
    if (remove && colorRows().length > 1) { remove.closest("[data-color-row]")?.remove(); publishColors(); persistState(); }
  });
  root?.querySelector("[data-add-color]")?.addEventListener("click", () => {
    appendColorRow(`Color ${colorCount + 1}`, "#7C3AED");
    publishColors();
    persistState();
  });
  root?.querySelector("[data-framework-reset]")?.addEventListener("click", () => {
    try { localStorage.removeItem(STORAGE_KEY); } catch { /* Ignore unavailable storage. */ }
    applyState(defaultState);
    publishAll();
    persistState();
  });
  window.setTimeout(publishAll, 0);
</script>

