---
import { ArrowUpRight, Check, Sparkles } from "@lucide/astro";
import AppSidebar from "../components/dashboard/AppSidebar.astro";
import "../styles/global.css";

const releases = [
  {
    date: "July 16, 2026",
    label: "Today",
    title: "The Framework is easier to use",
    summary: "We made the settings clearer, easier to read, and faster to change.",
    featured: true,
    changes: [
      { heading: "One Elements page", text: "There is now one clear page for finding and viewing HTML elements. We removed the test versions." },
      { heading: "Edit an element", text: "Pick an element, such as a heading or paragraph. You can then change its color, text size, and space." },
      { heading: "Better choice menus", text: "The new choice menus show names, values, and helpful icons. You can also use them with a keyboard." },
      { heading: "Clear open sections", text: "An open settings section now has a light blue background and border. This makes it easy to see where you are." },
      { heading: "Text is easier to read", text: "Labels and values are larger and use the same style. There is also more space between settings." },
      { heading: "Less clutter", text: "We removed extra labels, lines, and repeated details that did not help." },
      { heading: "Smoother navigation", text: "Long settings lists scroll better. The small Main menu also takes up less room." },
      { heading: "A new Changelog", text: "This page now shows what is new. Pages that are not ready yet have a Soon badge." },
    ],
  },
  {
    date: "July 15, 2026",
    title: "Safer app updates",
    summary: "We improved the tools that build and publish the app.",
    changes: [
      { heading: "New app engine", text: "The app now runs on Astro 7, a newer version of the tool used to build it." },
      { heading: "Update history", text: "We can now see when each Cloudflare update was published." },
      { heading: "Safer previews", text: "Work can be tested before it is sent to the main website." },
    ],
  },
  {
    date: "July 14, 2026",
    title: "Clear rules for the Framework",
    summary: "We wrote down what the Framework does and how other tools can use it.",
    changes: [
      { heading: "Shared words", text: "We chose clear names for the main parts of the product so everyone can talk about them in the same way." },
      { heading: "Clear limits", text: "We wrote down what the app saves, shows, and sends to other tools." },
      { heading: "Ready to publish", text: "We set up separate places for testing and for the live app." },
    ],
  },
  {
    date: "July 11–13, 2026",
    title: "More HTML elements",
    summary: "We added more elements and made them easier to find.",
    changes: [
      { heading: "A bigger list", text: "The app now knows about 92 HTML elements, such as headings, buttons, forms, and tables." },
      { heading: "Easy preview links", text: "You can move between the design system, website, and element views from the preview bar." },
      { heading: "More useful examples", text: "The previews use more real-looking pages, so it is easier to judge your choices." },
    ],
  },
  {
    date: "July 10, 2026",
    title: "The first design settings",
    summary: "We built the main tools for choosing how a website should look.",
    changes: [
      { heading: "Sizes that can grow", text: "Text, space, and rounded corners can change smoothly for small and large screens." },
      { heading: "Color jobs", text: "You can choose colors for jobs such as text, buttons, borders, and focus rings." },
      { heading: "Use your choices elsewhere", text: "You can copy or export the design values for another website or tool." },
    ],
  },
  {
    date: "June 30–July 8, 2026",
    title: "The first working app",
    summary: "We built the first version of techies.tools.",
    changes: [
      { heading: "Main menu and settings", text: "The first layout had a Main menu next to the Framework settings." },
      { heading: "A shared look", text: "We added the basic colors, spacing, and layout used by the app." },
      { heading: "See changes live", text: "The first preview showed design changes as soon as you made them." },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Product updates and release history for techies.tools." />
    <title>Changelog — techies.tools</title>
  </head>
  <body>
    <div class="changelog-shell">
      <AppSidebar />
      <main class="changelog">
        <header class="changelog__hero">
          <div class="changelog__eyebrow"><Sparkles size={14} /> Product updates</div>
          <h1>Changelog</h1>
          <p>See what is new in techies.tools and how each change helps you.</p>
        </header>

        <div class="changelog__timeline">
          {releases.map((release) => (
            <article class:list={["release", { "release--featured": release.featured }]}>
              <div class="release__rail" aria-hidden="true"><span></span></div>
              <div class="release__content">
                <header>
                  <div class="release__meta">
                    <time>{release.date}</time>
                    {release.label && <span>{release.label}</span>}
                  </div>
                  <h2>{release.title}</h2>
                  <p>{release.summary}</p>
                </header>
                <div class="release__changes">
                  {release.changes.map((change) => <section><span aria-hidden="true"><Check size={13} /></span><div><h3>{change.heading}</h3><p>{change.text}</p></div></section>)}
                </div>
              </div>
            </article>
          ))}
        </div>

        <footer class="changelog__footer">
          <i aria-hidden="true"><Sparkles size={22} /></i>
          <div><strong>Ready to shape your Framework?</strong><span>Choose your colors, type, space, and elements.</span></div>
          <p>Your choices work together in one live preview.</p>
          <a href="/">Open Framework <ArrowUpRight size={14} /></a>
        </footer>
      </main>
    </div>
  </body>
</html>

<style>
  .changelog-shell { display:grid; grid-template-columns:auto minmax(0,1fr); block-size:100vh; overflow:hidden; background:#fff; }
  .changelog { min-inline-size:0; overflow:auto; background:linear-gradient(180deg,#f8faff 0,#fff 28rem); }
  .changelog__hero { max-inline-size:70rem; margin:0 auto; padding:5.5rem 4rem 4.25rem; }
  .changelog__eyebrow { display:flex; align-items:center; gap:.45rem; margin-bottom:1.15rem; color:#2563eb; font-size:.75rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase; }
  .changelog__hero h1 { max-inline-size:12ch; margin:0; color:#0f172a; font-size:clamp(3rem,6vw,5.75rem); font-weight:760; letter-spacing:-.065em; line-height:.92; }
  .changelog__hero p { max-inline-size:42rem; margin:1.5rem 0 0; color:#64748b; font-size:1.125rem; line-height:1.65; }
  .changelog__timeline { max-inline-size:70rem; margin:0 auto; padding:0 4rem 4rem; }
  .release { display:grid; grid-template-columns:2.75rem minmax(0,1fr); }
  .release__rail { position:relative; display:flex; justify-content:center; }
  .release__rail::after { position:absolute; inset-block:1.3rem 0; inline-size:1px; background:#dbe3ef; content:""; }
  .release:last-child .release__rail::after { display:none; }
  .release__rail span { position:relative; z-index:1; inline-size:.7rem; block-size:.7rem; margin-top:1.83rem; border:2px solid #fff; border-radius:50%; background:#94a3b8; box-shadow:0 0 0 1px #cbd5e1; }
  .release__content { margin-bottom:3.25rem; padding:0; }
  .release--featured .release__rail span { inline-size:.85rem; block-size:.85rem; margin-top:2.09rem; background:#2563eb; box-shadow:0 0 0 4px #dbeafe; }
  .release__meta { display:flex; align-items:center; gap:.65rem; margin-bottom:.125rem; }
  .release__meta time { color:#64748b; font-size:.72rem; font-weight:750; letter-spacing:.06em; text-transform:uppercase; }
  .release__meta span { border-radius:999px; padding:.22rem .55rem; background:#dbeafe; color:#1d4ed8; font-size:.65rem; font-weight:800; text-transform:uppercase; }
  .release h2 { margin:0; color:#0f172a; font-size:1.7rem; letter-spacing:-.035em; }
  .release header>p { max-inline-size:44rem; margin:.55rem 0 0; color:#64748b; font-size:.95rem; line-height:1.6; }
  .release__changes { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:1.75rem 3rem; margin-top:2rem; }
  .release__changes section { display:grid; grid-template-columns:1.75rem minmax(0,1fr); align-items:start; gap:.7rem; }
  .release__changes section>span { display:grid; place-items:center; inline-size:1.75rem; block-size:1.75rem; border-radius:50%; background:#eff6ff; color:#2563eb; }
  .release__changes h3 { margin:.12rem 0 .35rem; color:#172033; font-size:.92rem; line-height:1.35; }
  .release__changes p { max-inline-size:34rem; margin:0; color:#64748b; font-size:.82rem; line-height:1.6; }
  .changelog__footer { display:grid; grid-template-columns:auto 1.2fr 1fr auto; align-items:center; gap:1.5rem; max-inline-size:63.5rem; margin:0 auto 5rem; border-radius:999px; padding:1.25rem 1.4rem; background:#2563eb; color:#fff; }
  .changelog__footer>i { display:grid; place-items:center; inline-size:3.5rem; block-size:3.5rem; border:1px solid rgb(255 255 255/.45); border-radius:50%; font-style:normal; }
  .changelog__footer div { display:grid; gap:.3rem; }
  .changelog__footer strong { font-size:1.05rem; }
  .changelog__footer span,.changelog__footer>p { margin:0; color:rgb(255 255 255/.78); font-size:.82rem; line-height:1.5; }
  .changelog__footer a { display:flex; align-items:center; justify-content:center; gap:.4rem; min-block-size:2.75rem; border-radius:999px; padding:.65rem 1rem; background:#fff; color:#1d4ed8; font-size:.82rem; font-weight:800; text-decoration:none; white-space:nowrap; }
  @media (max-width:900px) { .changelog__hero,.changelog__timeline { padding-inline:2rem; } .release__changes { grid-template-columns:1fr; } .changelog__footer { margin-inline:2rem; } }
  @media (max-width:720px) { .changelog-shell { grid-template-columns:1fr; align-content:start; overflow:auto; } .changelog { overflow:visible; } .changelog__hero { padding-block:3.5rem 3rem; } .release { grid-template-columns:1.5rem minmax(0,1fr); } .changelog__footer { grid-template-columns:auto 1fr; border-radius:1.25rem; } .changelog__footer>p { grid-column:2; } .changelog__footer>a { grid-column:1/-1; } }
</style>
