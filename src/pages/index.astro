---
import DashboardShell from "../components/dashboard/DashboardShell.astro";
import DesignSystemPreview from "../components/dashboard/DesignSystemPreview.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Framework prototype</title>
  </head>
  <body>
    <DashboardShell>
      <section class="framework-preview" aria-label="Live framework preview">
        <DesignSystemPreview />
      </section>
    </DashboardShell>
  </body>
</html>

<style>
  .framework-preview {
    block-size: 100%;
    min-block-size: 0;
    overflow: hidden;
  }
</style>
