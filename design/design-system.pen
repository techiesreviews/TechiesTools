            {
              "type": "frame",
              "id": "QIEE9",
              "name": "Comparison notes",
              "width": "fill_container",
              "height": "fill_container",
              "fill": "#FFFFFF",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "#E5E7EB"
              },
              "layout": "vertical",
              "gap": 14,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "LMeRk",
                  "name": "nt",
                  "fill": "#111827",
                  "content": "UX tradeoffs",
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "800"
                },
                {
                  "type": "text",
                  "id": "bO2ry",
                  "name": "n1",
                  "fill": "#6B7280",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Preset-driven is fastest for users who want a coherent scale without editing each token. Ladder editor is best when users think in visual hierarchy. Role defaults are best when the framework exposes semantic defaults first and advanced scale details second.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "500"
                },
                {
                  "type": "frame",
                  "id": "hlwTl",
                  "name": "rec",
                  "width": "fill_container",
                  "fill": "#EFF6FF",
                  "cornerRadius": 8,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1,
                    "fill": "#BFDBFE"
                  },
                  "layout": "vertical",
                  "gap": 8,
                  "padding": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "JbTrS",
                      "name": "rect",
                      "fill": "#1E40AF",
                      "content": "Recommendation",
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "800"
                    },
                    {
                      "type": "text",
                      "id": "ZskjW",
                      "name": "recc",
                      "fill": "#1D4ED8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Use role defaults as the default view, with scale presets as an advanced control. It matches how people choose Heading and Body first, then tune the system.",
