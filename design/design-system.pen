                {
                  "type": "text",
                  "id": "p098j",
                  "name": "nc",
                  "fill": "#6B7280",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Use roles as the user-facing layer and families as assignable resources. The collapsed Type row can preview font diversity with tiny Aa samples the same way Colors previews variation count with dots. This handles Heading, Body, Accent, Code, Caption, and future roles without adding more accordion sections.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
